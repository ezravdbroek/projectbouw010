---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Gratis Offerte Aanvragen | Projectbouw 010" description="Vraag een gratis en vrijblijvende offerte aan voor uw renovatie of verbouwing in Rotterdam. Reactie binnen 24 uur.">
  <!-- Hero Banner -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=1920&q=80"
        alt="Verbouwing werkzaamheden"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-primary/90 to-primary"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="fade-in text-gray-400 font-medium tracking-widest uppercase text-sm mb-4">Vrijblijvend & Gratis</p>
      <h1 class="fade-in fade-in-delay-1 text-4xl sm:text-5xl font-heading font-bold text-white mb-4">
        Offerte Aanvragen
      </h1>
      <p class="fade-in fade-in-delay-2 text-gray-300 text-lg max-w-xl mx-auto">
        Vul het formulier in en ontvang binnen 24 uur een vrijblijvende offerte op maat.
      </p>
    </div>
  </section>

  <!-- Form Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Form (3 cols) -->
        <div class="lg:col-span-3">
          <form id="offerte-form" class="fade-in space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="naam" class="block text-sm font-medium text-gray-300 mb-1.5">Naam *</label>
                <input
                  type="text"
                  id="naam"
                  name="naam"
                  required
                  class="w-full bg-white/5 border border-white/10 rounded px-4 py-3 text-white placeholder:text-gray-500 focus:outline-none focus:border-white/40 transition-colors"
                  placeholder="Uw volledige naam"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-300 mb-1.5">E-mail *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full bg-white/5 border border-white/10 rounded px-4 py-3 text-white placeholder:text-gray-500 focus:outline-none focus:border-white/40 transition-colors"
                  placeholder="uw@email.nl"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="telefoon" class="block text-sm font-medium text-gray-300 mb-1.5">Telefoon *</label>
                <input
                  type="tel"
                  id="telefoon"
                  name="telefoon"
                  required
                  class="w-full bg-white/5 border border-white/10 rounded px-4 py-3 text-white placeholder:text-gray-500 focus:outline-none focus:border-white/40 transition-colors"
                  placeholder="06-12345678"
                />
              </div>
              <div>
                <label for="type" class="block text-sm font-medium text-gray-300 mb-1.5">Type werkzaamheden</label>
                <select
                  id="type"
                  name="type"
                  class="w-full bg-white/5 border border-white/10 rounded px-4 py-3 text-white focus:outline-none focus:border-white/40 transition-colors appearance-none"
                >
                  <option value="" class="bg-primary">Selecteer...</option>
                  <option value="aanbouw" class="bg-primary">Aanbouw / Uitbouw / Opbouw</option>
                  <option value="badkamer" class="bg-primary">Badkamer Renovatie</option>
                  <option value="keuken" class="bg-primary">Keukenrenovatie</option>
                  <option value="stalen-deuren" class="bg-primary">Stalen Deuren</option>
                  <option value="stucwerk" class="bg-primary">Stucwerk</option>
                  <option value="tegelwerk" class="bg-primary">Tegelwerk</option>
                  <option value="vloeren" class="bg-primary">Vloeren</option>
                  <option value="traprenovatie" class="bg-primary">Traprenovatie</option>
                  <option value="overig" class="bg-primary">Overig</option>
                </select>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
              <div class="sm:col-span-2">
                <label for="straat" class="block text-sm font-medium text-gray-300 mb-1.5">Straat + huisnummer</label>
                <input
                  type="text"
                  id="straat"
                  name="straat"
                  class="w-full bg-white/5 border border-white/10 rounded px-4 py-3 text-white placeholder:text-gray-500 focus:outline-none focus:border-white/40 transition-colors"
                  placeholder="Straatnaam 123"
                />
              </div>
              <div>
                <label for="postcode" class="block text-sm font-medium text-gray-300 mb-1.5">Postcode</label>
                <input
                  type="text"
                  id="postcode"
                  name="postcode"
                  class="w-full bg-white/5 border border-white/10 rounded px-4 py-3 text-white placeholder:text-gray-500 focus:outline-none focus:border-white/40 transition-colors"
                  placeholder="1234 AB"
                />
              </div>
            </div>

            <div>
              <label for="woonplaats" class="block text-sm font-medium text-gray-300 mb-1.5">Woonplaats</label>
              <input
                type="text"
                id="woonplaats"
                name="woonplaats"
                class="w-full bg-white/5 border border-white/10 rounded px-4 py-3 text-white placeholder:text-gray-500 focus:outline-none focus:border-white/40 transition-colors"
                placeholder="Rotterdam"
              />
            </div>

            <div>
              <label for="omschrijving" class="block text-sm font-medium text-gray-300 mb-1.5">Omschrijving werkzaamheden *</label>
              <textarea
                id="omschrijving"
                name="omschrijving"
                rows="5"
                required
                class="w-full bg-white/5 border border-white/10 rounded px-4 py-3 text-white placeholder:text-gray-500 focus:outline-none focus:border-white/40 transition-colors resize-none"
                placeholder="Beschrijf zo duidelijk mogelijk welke werkzaamheden u wilt laten uitvoeren..."
              ></textarea>
            </div>

            <!-- File uploads -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="fotos-huidig" class="block text-sm font-medium text-gray-300 mb-1.5">
                  Huidige situatie (foto's)
                </label>
                <p class="text-xs text-gray-500 mb-2">Foto's van hoe het er nu uitziet</p>
                <label
                  for="fotos-huidig"
                  class="flex flex-col items-center justify-center w-full h-28 bg-white/5 border-2 border-dashed border-white/10 rounded-lg cursor-pointer hover:border-white/30 transition-colors"
                >
                  <Icon name="lucide:camera" class="w-6 h-6 text-gray-400 mb-1" />
                  <span class="text-gray-400 text-xs">Klik om foto's te uploaden</span>
                  <span id="huidig-count" class="text-gray-500 text-xs mt-1"></span>
                </label>
                <input type="file" id="fotos-huidig" name="fotos-huidig" multiple accept="image/*" class="hidden" />
              </div>
              <div>
                <label for="fotos-gewenst" class="block text-sm font-medium text-gray-300 mb-1.5">
                  Gewenste situatie (inspiratie)
                </label>
                <p class="text-xs text-gray-500 mb-2">Voorbeeldfoto's van wat u wilt</p>
                <label
                  for="fotos-gewenst"
                  class="flex flex-col items-center justify-center w-full h-28 bg-white/5 border-2 border-dashed border-white/10 rounded-lg cursor-pointer hover:border-white/30 transition-colors"
                >
                  <Icon name="lucide:image" class="w-6 h-6 text-gray-400 mb-1" />
                  <span class="text-gray-400 text-xs">Klik om foto's te uploaden</span>
                  <span id="gewenst-count" class="text-gray-500 text-xs mt-1"></span>
                </label>
                <input type="file" id="fotos-gewenst" name="fotos-gewenst" multiple accept="image/*" class="hidden" />
              </div>
            </div>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                class="mt-1 w-4 h-4 accent-white"
              />
              <label for="privacy" class="text-sm text-gray-400">
                Ik ga akkoord met de verwerking van mijn gegevens voor het behandelen van deze offerte-aanvraag. *
              </label>
            </div>

            <button
              type="submit"
              class="w-full sm:w-auto bg-white hover:bg-gray-200 text-primary px-10 py-4 font-semibold rounded text-lg transition-colors duration-200"
            >
              Verstuur Aanvraag
            </button>

            <!-- Status message -->
            <div id="form-status" class="hidden rounded p-4 text-sm"></div>
          </form>
        </div>

        <!-- Benefits (2 cols) -->
        <div class="lg:col-span-2">
          <div class="fade-in fade-in-delay-2 bg-white/5 border border-white/10 rounded-lg p-8 sticky top-28">
            <h3 class="text-white font-heading font-bold text-xl mb-6">Waarom Projectbouw 010?</h3>
            <ul class="space-y-5">
              <li class="flex items-start gap-3">
                <div class="w-8 h-8 bg-white/10 rounded flex items-center justify-center shrink-0 mt-0.5">
                  <Icon name="lucide:badge-check" class="w-4 h-4 text-white" />
                </div>
                <div>
                  <p class="text-white font-medium">Gratis & Vrijblijvend</p>
                  <p class="text-gray-400 text-sm">Onze offertes zijn altijd kosteloos en zonder verplichtingen.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-8 h-8 bg-white/10 rounded flex items-center justify-center shrink-0 mt-0.5">
                  <Icon name="lucide:clock" class="w-4 h-4 text-white" />
                </div>
                <div>
                  <p class="text-white font-medium">Reactie Binnen 24 Uur</p>
                  <p class="text-gray-400 text-sm">U hoort snel van ons. Wij nemen binnen een werkdag contact op.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-8 h-8 bg-white/10 rounded flex items-center justify-center shrink-0 mt-0.5">
                  <Icon name="lucide:calculator" class="w-4 h-4 text-white" />
                </div>
                <div>
                  <p class="text-white font-medium">All-in Prijzen</p>
                  <p class="text-gray-400 text-sm">Geen verborgen kosten. De prijs die u ziet, is de prijs die u betaalt.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-8 h-8 bg-white/10 rounded flex items-center justify-center shrink-0 mt-0.5">
                  <Icon name="lucide:shield-check" class="w-4 h-4 text-white" />
                </div>
                <div>
                  <p class="text-white font-medium">4 Jaar Garantie</p>
                  <p class="text-gray-400 text-sm">Op al onze werkzaamheden geven wij 4 jaar garantie.</p>
                </div>
              </li>
            </ul>

            <hr class="border-white/10 my-6" />

            <h4 class="text-white font-medium mb-4">Direct contact?</h4>
            <div class="space-y-3">
              <a href="tel:0653999433" class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors text-sm">
                <Icon name="lucide:phone" class="w-4 h-4 text-white" />
                06-53999433
              </a>
              <a href="mailto:info@projectbouw010.nl" class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors text-sm">
                <Icon name="lucide:mail" class="w-4 h-4 text-white" />
                info@projectbouw010.nl
              </a>
              <a href="https://wa.me/31653999433" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors text-sm">
                <Icon name="lucide:message-circle" class="w-4 h-4 text-white" />
                WhatsApp bericht sturen
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('offerte-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;

  // File upload count display
  document.getElementById('fotos-huidig')!.addEventListener('change', (e) => {
    const count = (e.target as HTMLInputElement).files?.length || 0;
    document.getElementById('huidig-count')!.textContent = count > 0 ? `${count} foto('s) geselecteerd` : '';
  });
  document.getElementById('fotos-gewenst')!.addEventListener('change', (e) => {
    const count = (e.target as HTMLInputElement).files?.length || 0;
    document.getElementById('gewenst-count')!.textContent = count > 0 ? `${count} foto('s) geselecteerd` : '';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Verzenden...';

    try {
      const res = await fetch('/api/offerte', {
        method: 'POST',
        body: data,
      });

      if (res.ok) {
        status.className = 'rounded p-4 text-sm bg-green-500/10 border border-green-500/30 text-green-300';
        status.textContent = 'Bedankt voor uw aanvraag! Wij nemen binnen 24 uur contact met u op.';
        form.reset();
      } else {
        throw new Error('Server error');
      }
    } catch {
      status.className = 'rounded p-4 text-sm bg-red-500/10 border border-red-500/30 text-red-300';
      status.textContent = 'Er is iets misgegaan. Probeer het opnieuw of neem telefonisch contact op.';
    } finally {
      status.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Verstuur Aanvraag';
    }
  });
</script>
