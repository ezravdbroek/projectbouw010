---
import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { diensten } from '../../data/diensten';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return diensten.map((d) => ({
    params: { slug: d.slug },
    props: { dienst: d },
  }));
};

const { dienst } = Astro.props;

const gerelateerd = diensten.filter((d) => d.slug !== dienst.slug).slice(0, 4);
---

<Layout
  title={`${dienst.naam} | Projectbouw 010 Rotterdam`}
  description={dienst.omschrijving}
>
  <!-- Hero Banner -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0">
      <img src={dienst.afbeelding} alt={dienst.naam} class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#111]/80 to-[#111]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="reveal-up flex items-center gap-2 text-sm text-[#777] mb-8">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <a href="/#diensten" class="hover:text-white transition-colors">Diensten</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <span class="text-white">{dienst.naam}</span>
      </nav>
      <h1 class="reveal-up text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-white uppercase" style="--delay: 0.1s">
        {dienst.naam}
      </h1>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main content -->
        <div class="lg:col-span-2">
          <div class="reveal-up">
            <p class="text-[#333] text-lg leading-relaxed mb-8">{dienst.omschrijving}</p>

            <h2 class="text-2xl font-heading font-bold text-[#111] uppercase mb-6">Wat wij voor u doen</h2>
            <ul class="space-y-4 mb-12">
              {dienst.kenmerken.map((k) => (
                <li class="flex items-start gap-3">
                  <div class="w-6 h-6 bg-[#f4f4f4] rounded flex items-center justify-center shrink-0 mt-0.5">
                    <Icon name="lucide:check" class="w-3.5 h-3.5 text-[#111]" />
                  </div>
                  <span class="text-[#333]">{k}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="reveal-up" style="--delay: 0.1s">
            <img src={dienst.afbeelding} alt={dienst.naam} class="rounded-xl w-full object-cover aspect-video" loading="lazy" />
          </div>
        </div>

        <!-- Sidebar CTA -->
        <div class="reveal-right" style="--delay: 0.2s">
          <div class="rounded-xl border border-[#e0e0e0] p-8 sticky top-28">
            <h3 class="text-[#111] font-heading font-bold text-xl uppercase mb-4">Offerte aanvragen</h3>
            <p class="text-[#777] text-sm mb-6">
              Vraag een gratis en vrijblijvende offerte aan voor uw {dienst.naam.toLowerCase()} project.
            </p>
            <a
              href="/offerte-aanvragen"
              class="block text-center bg-[#111] hover:bg-[#333] text-white px-6 py-3.5 font-semibold rounded transition-colors duration-200 mb-4"
            >
              Gratis Offerte
            </a>
            <a
              href="tel:0653999433"
              class="block text-center border border-[#e0e0e0] hover:border-[#111] text-[#111] px-6 py-3.5 font-semibold rounded transition-all duration-200"
            >
              <span class="flex items-center justify-center gap-2">
                <Icon name="lucide:phone" class="w-4 h-4" />
                06-53999433
              </span>
            </a>

            <hr class="border-[#e0e0e0] my-6" />

            <ul class="space-y-3 text-sm">
              <li class="flex items-center gap-2 text-[#777]">
                <Icon name="lucide:shield-check" class="w-4 h-4 text-[#111]" />
                4 jaar garantie
              </li>
              <li class="flex items-center gap-2 text-[#777]">
                <Icon name="lucide:clock" class="w-4 h-4 text-[#111]" />
                Reactie binnen 24 uur
              </li>
              <li class="flex items-center gap-2 text-[#777]">
                <Icon name="lucide:badge-check" class="w-4 h-4 text-[#111]" />
                All-in prijzen
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gerelateerde diensten -->
  <section class="py-16 lg:py-20 bg-[#f4f4f4]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="reveal-up text-2xl sm:text-3xl font-heading font-bold text-[#111] uppercase mb-8">Andere Diensten</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {gerelateerd.map((d, i) => (
          <a href={`/diensten/${d.slug}`} class="reveal-up relative rounded-xl overflow-hidden group aspect-[4/3]" style={`--delay: ${i * 0.05}s`}>
            <img src={d.afbeelding} alt={d.naam} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#111]/90 via-[#111]/30 to-transparent"></div>
            <div class="relative h-full flex items-end p-4">
              <h3 class="text-white font-heading font-bold text-lg uppercase">{d.naam}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
