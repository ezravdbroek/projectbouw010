---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { diensten } from '../data/diensten';
---

<Layout title="Gratis Offerte Aanvragen | Projectbouw 010" description="Vraag een gratis en vrijblijvende offerte aan voor uw renovatie of verbouwing in Rotterdam. Reactie binnen 24 uur.">
  <!-- Hero — Full width with image -->
  <section class="relative pt-40 pb-24 lg:pt-48 lg:pb-32 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero.jpg" alt="Verbouwing werkzaamheden" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#111]/60 via-[#111]/70 to-[#111]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="reveal-up flex items-center gap-2 text-sm text-white/50 mb-8">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <span class="text-white">Offerte Aanvragen</span>
      </nav>
      <h1 class="reveal-up text-4xl sm:text-5xl lg:text-7xl font-heading font-bold text-white uppercase leading-[0.95]" style="--delay: 0.1s">
        Gratis Offerte<br />Aanvragen
      </h1>
      <p class="reveal-up text-gray-300 text-lg sm:text-xl max-w-2xl mt-6 leading-relaxed" style="--delay: 0.2s">
        Vul het formulier in en ontvang binnen 24 uur een vrijblijvende offerte op maat. Geen verborgen kosten.
      </p>
    </div>
  </section>

  <!-- USPs strip -->
  <section class="py-6 bg-[#111] border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { icon: 'lucide:badge-check', text: 'Gratis & Vrijblijvend' },
          { icon: 'lucide:clock', text: 'Reactie Binnen 24 Uur' },
          { icon: 'lucide:calculator', text: 'All-in Prijzen' },
          { icon: 'lucide:shield-check', text: '4 Jaar Garantie' },
        ].map((usp) => (
          <div class="flex items-center gap-3">
            <Icon name={usp.icon} class="w-5 h-5 text-white shrink-0" />
            <p class="text-white font-medium text-sm">{usp.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Form Section -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Form (3 cols) -->
        <div class="lg:col-span-3">
          <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Formulier</p>
          <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-[#111] uppercase mb-8" style="--delay: 0.1s">
            Vertel Ons Over Uw Project
          </h2>

          <form id="offerte-form" class="reveal-up space-y-5" style="--delay: 0.15s">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="naam" class="block text-sm font-medium text-[#333] mb-1.5">Naam *</label>
                <input
                  type="text"
                  id="naam"
                  name="naam"
                  required
                  class="w-full bg-[#f4f4f4] border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  placeholder="Uw volledige naam"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-[#333] mb-1.5">E-mail *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full bg-[#f4f4f4] border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  placeholder="uw@email.nl"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="telefoon" class="block text-sm font-medium text-[#333] mb-1.5">Telefoon *</label>
                <input
                  type="tel"
                  id="telefoon"
                  name="telefoon"
                  required
                  class="w-full bg-[#f4f4f4] border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  placeholder="06-12345678"
                />
              </div>
              <div>
                <label for="type" class="block text-sm font-medium text-[#333] mb-1.5">Type werkzaamheden</label>
                <select
                  id="type"
                  name="type"
                  class="w-full bg-[#f4f4f4] border border-[#e0e0e0] rounded px-4 py-3 text-[#111] focus:outline-none focus:border-[#111] transition-colors appearance-none"
                >
                  <option value="" class="bg-white">Selecteer...</option>
                  {diensten.map((d) => (
                    <option value={d.slug} class="bg-white">{d.naam}</option>
                  ))}
                  <option value="overig" class="bg-white">Overig</option>
                </select>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
              <div class="sm:col-span-2">
                <label for="straat" class="block text-sm font-medium text-[#333] mb-1.5">Straat + huisnummer</label>
                <input
                  type="text"
                  id="straat"
                  name="straat"
                  class="w-full bg-[#f4f4f4] border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  placeholder="Straatnaam 123"
                />
              </div>
              <div>
                <label for="postcode" class="block text-sm font-medium text-[#333] mb-1.5">Postcode</label>
                <input
                  type="text"
                  id="postcode"
                  name="postcode"
                  class="w-full bg-[#f4f4f4] border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  placeholder="1234 AB"
                />
              </div>
            </div>

            <div>
              <label for="woonplaats" class="block text-sm font-medium text-[#333] mb-1.5">Woonplaats</label>
              <input
                type="text"
                id="woonplaats"
                name="woonplaats"
                class="w-full bg-[#f4f4f4] border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                placeholder="Rotterdam"
              />
            </div>

            <div>
              <label for="omschrijving" class="block text-sm font-medium text-[#333] mb-1.5">Omschrijving werkzaamheden *</label>
              <textarea
                id="omschrijving"
                name="omschrijving"
                rows="5"
                required
                class="w-full bg-[#f4f4f4] border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors resize-none"
                placeholder="Beschrijf zo duidelijk mogelijk welke werkzaamheden u wilt laten uitvoeren..."
              ></textarea>
            </div>

            <!-- File uploads -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="fotos-huidig" class="block text-sm font-medium text-[#333] mb-1.5">
                  Huidige situatie (foto's)
                </label>
                <p class="text-xs text-[#777] mb-2">Foto's van hoe het er nu uitziet</p>
                <label
                  for="fotos-huidig"
                  class="flex flex-col items-center justify-center w-full h-28 bg-[#f4f4f4] border-2 border-dashed border-[#e0e0e0] rounded-lg cursor-pointer hover:border-[#111] transition-colors"
                >
                  <Icon name="lucide:camera" class="w-6 h-6 text-[#777] mb-1" />
                  <span class="text-[#777] text-xs">Klik om foto's te uploaden</span>
                  <span id="huidig-count" class="text-[#777] text-xs mt-1"></span>
                </label>
                <input type="file" id="fotos-huidig" name="fotos-huidig" multiple accept="image/*" class="hidden" />
              </div>
              <div>
                <label for="fotos-gewenst" class="block text-sm font-medium text-[#333] mb-1.5">
                  Gewenste situatie (inspiratie)
                </label>
                <p class="text-xs text-[#777] mb-2">Voorbeeldfoto's van wat u wilt</p>
                <label
                  for="fotos-gewenst"
                  class="flex flex-col items-center justify-center w-full h-28 bg-[#f4f4f4] border-2 border-dashed border-[#e0e0e0] rounded-lg cursor-pointer hover:border-[#111] transition-colors"
                >
                  <Icon name="lucide:image" class="w-6 h-6 text-[#777] mb-1" />
                  <span class="text-[#777] text-xs">Klik om foto's te uploaden</span>
                  <span id="gewenst-count" class="text-[#777] text-xs mt-1"></span>
                </label>
                <input type="file" id="fotos-gewenst" name="fotos-gewenst" multiple accept="image/*" class="hidden" />
              </div>
            </div>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                class="mt-1 w-4 h-4 accent-[#111]"
              />
              <label for="privacy" class="text-sm text-[#555]">
                Ik ga akkoord met de verwerking van mijn gegevens voor het behandelen van deze offerte-aanvraag. *
              </label>
            </div>

            <button
              type="submit"
              class="w-full sm:w-auto bg-[#111] hover:bg-[#333] text-white px-10 py-4 font-semibold rounded text-lg transition-colors duration-200"
            >
              Verstuur Aanvraag
            </button>

            <!-- Status message -->
            <div id="form-status" class="hidden rounded p-4 text-sm"></div>
          </form>
        </div>

        <!-- Sidebar (2 cols) -->
        <div class="lg:col-span-2">
          <div class="reveal-right sticky top-28 space-y-6" style="--delay: 0.2s">
            <!-- Waarom wij -->
            <div class="rounded-xl border border-[#e0e0e0] p-8">
              <h3 class="text-[#111] font-heading font-bold text-xl uppercase mb-6">Waarom Projectbouw 010?</h3>
              <ul class="space-y-5">
                <li class="flex items-start gap-3">
                  <div class="w-8 h-8 bg-[#f4f4f4] rounded flex items-center justify-center shrink-0 mt-0.5">
                    <Icon name="lucide:badge-check" class="w-4 h-4 text-[#111]" />
                  </div>
                  <div>
                    <p class="text-[#111] font-medium">Gratis & Vrijblijvend</p>
                    <p class="text-[#777] text-sm">Onze offertes zijn altijd kosteloos en zonder verplichtingen.</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <div class="w-8 h-8 bg-[#f4f4f4] rounded flex items-center justify-center shrink-0 mt-0.5">
                    <Icon name="lucide:clock" class="w-4 h-4 text-[#111]" />
                  </div>
                  <div>
                    <p class="text-[#111] font-medium">Reactie Binnen 24 Uur</p>
                    <p class="text-[#777] text-sm">U hoort snel van ons. Wij nemen binnen een werkdag contact op.</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <div class="w-8 h-8 bg-[#f4f4f4] rounded flex items-center justify-center shrink-0 mt-0.5">
                    <Icon name="lucide:calculator" class="w-4 h-4 text-[#111]" />
                  </div>
                  <div>
                    <p class="text-[#111] font-medium">All-in Prijzen</p>
                    <p class="text-[#777] text-sm">Geen verborgen kosten. De prijs die u ziet, is de prijs die u betaalt.</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <div class="w-8 h-8 bg-[#f4f4f4] rounded flex items-center justify-center shrink-0 mt-0.5">
                    <Icon name="lucide:shield-check" class="w-4 h-4 text-[#111]" />
                  </div>
                  <div>
                    <p class="text-[#111] font-medium">4 Jaar Garantie</p>
                    <p class="text-[#777] text-sm">Op al onze werkzaamheden geven wij 4 jaar garantie.</p>
                  </div>
                </li>
              </ul>
            </div>

            <!-- Direct contact -->
            <div class="rounded-xl bg-[#111] p-8">
              <h4 class="text-white font-heading font-bold text-lg uppercase mb-4">Direct Contact?</h4>
              <div class="space-y-3">
                <a href="tel:0653999433" class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors text-sm">
                  <Icon name="lucide:phone" class="w-4 h-4 text-white" />
                  06-53999433
                </a>
                <a href="mailto:info@projectbouw010.nl" class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors text-sm">
                  <Icon name="lucide:mail" class="w-4 h-4 text-white" />
                  info@projectbouw010.nl
                </a>
                <a href="https://wa.me/31653999433" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors text-sm">
                  <Icon name="lucide:message-circle" class="w-4 h-4 text-white" />
                  WhatsApp bericht sturen
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('offerte-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;

  // File upload count display
  document.getElementById('fotos-huidig')!.addEventListener('change', (e) => {
    const count = (e.target as HTMLInputElement).files?.length || 0;
    document.getElementById('huidig-count')!.textContent = count > 0 ? `${count} foto('s) geselecteerd` : '';
  });
  document.getElementById('fotos-gewenst')!.addEventListener('change', (e) => {
    const count = (e.target as HTMLInputElement).files?.length || 0;
    document.getElementById('gewenst-count')!.textContent = count > 0 ? `${count} foto('s) geselecteerd` : '';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Verzenden...';

    try {
      const res = await fetch('/api/offerte', {
        method: 'POST',
        body: data,
      });

      if (res.ok) {
        status.className = 'rounded p-4 text-sm bg-green-500/10 border border-green-500/30 text-green-700';
        status.textContent = 'Bedankt voor uw aanvraag! Wij nemen binnen 24 uur contact met u op.';
        form.reset();
      } else {
        throw new Error('Server error');
      }
    } catch {
      status.className = 'rounded p-4 text-sm bg-red-500/10 border border-red-500/30 text-red-700';
      status.textContent = 'Er is iets misgegaan. Probeer het opnieuw of neem telefonisch contact op.';
    } finally {
      status.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Verstuur Aanvraag';
    }
  });
</script>
