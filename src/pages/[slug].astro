---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { pseoServices, locaties, type PseoService, type PseoLocatie } from '../data/pseo';
import type { GetStaticPaths } from 'astro';

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/**/*.{jpeg,jpg,png}', { eager: true });

function getImage(path: string) {
  const img = images[path];
  if (!img) return path;
  return img.default;
}

export const getStaticPaths: GetStaticPaths = () => {
  const paths: any[] = [];
  for (const service of pseoServices) {
    for (const locatie of locaties) {
      paths.push({
        params: { slug: `${service.slug}-${locatie.slug}` },
        props: { service, locatie },
      });
    }
  }
  return paths;
};

const { service, locatie } = Astro.props as { service: PseoService; locatie: PseoLocatie };

const faqItems = service.faq(locatie.naam);
const andereDiensten = pseoServices.filter((s) => s.slug !== service.slug);

const werkwijzeStappen = [
  { number: '01', title: 'Contact & Opname', icon: 'lucide:phone', desc: `Wij bespreken uw wensen en komen langs in ${locatie.naam} voor een vrijblijvende opname.` },
  { number: '02', title: 'Offerte Op Maat', icon: 'lucide:file-text', desc: 'U ontvangt een duidelijke, all-in offerte. Geen verborgen kosten, geen verrassingen.' },
  { number: '03', title: 'Vakkundige Uitvoering', icon: 'lucide:hammer', desc: 'Ons team gaat aan de slag. U wordt continu op de hoogte gehouden van de voortgang.' },
  { number: '04', title: 'Oplevering & Garantie', icon: 'lucide:check-circle', desc: 'Samen lopen we het resultaat na. Pas als u tevreden bent, is het klaar. Met 4 jaar garantie.' },
];

const pageTitle = `${service.naam} ${locatie.naam} | Projectbouw 010`;
const pageDesc = `${service.naam} in ${locatie.naam}? Projectbouw 010 is uw specialist voor ${service.meervoud} in ${locatie.naam} en ${locatie.regio}. Gratis offerte, all-in prijzen, 4 jaar garantie.`;

const schemaOrg = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${service.naam} ${locatie.naam}`,
  description: pageDesc,
  provider: {
    '@type': 'HomeImprovement',
    name: 'Projectbouw 010',
    telephone: '+31653999433',
    email: 'info@projectbouw010.nl',
    url: 'https://projectbouw010.nl',
    areaServed: { '@type': 'City', name: locatie.naam },
    aggregateRating: { '@type': 'AggregateRating', ratingValue: '9.3', ratingCount: '173', bestRating: '10' },
  },
  areaServed: { '@type': 'City', name: locatie.naam },
});
---

<Layout title={pageTitle} description={pageDesc}>
  <script type="application/ld+json" set:html={schemaOrg} />

  <!-- Hero -->
  <section class="relative pt-40 pb-24 lg:pt-48 lg:pb-32 overflow-hidden">
    <div class="absolute inset-0">
      <Image src={getImage(service.afbeelding)} alt={`${service.naam} in ${locatie.naam}`} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#111]/60 via-[#111]/70 to-[#111]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="reveal-up flex items-center gap-2 text-sm text-white/50 mb-8">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <a href={`/diensten/${service.gerelateerdeSlug}`} class="hover:text-white transition-colors">{service.naam}</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <span class="text-white">{locatie.naam}</span>
      </nav>
      <span class="reveal-up inline-block bg-white/10 backdrop-blur-sm text-white text-xs font-medium uppercase tracking-wider px-3 py-1 rounded" style="--delay: 0.05s">
        {locatie.naam} &middot; {locatie.regio}
      </span>
      <h1 class="reveal-up text-4xl sm:text-5xl lg:text-7xl font-heading font-bold text-white uppercase leading-[0.95] mt-4" style="--delay: 0.1s">
        {service.naam}<br />{locatie.naam}
      </h1>
      <p class="reveal-up text-gray-300 text-lg sm:text-xl max-w-2xl mt-6 leading-relaxed" style="--delay: 0.2s">
        Specialist in {service.meervoud} in {locatie.naam} en omgeving. Vakmanschap, all-in prijzen en 4 jaar garantie.
      </p>
      <div class="reveal-up flex flex-col sm:flex-row gap-4 mt-10" style="--delay: 0.3s">
        <a href={`/offerte-aanvragen?bron=/${service.slug}-${locatie.slug}`} class="bg-white text-[#111] px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 text-center hover:bg-gray-200">
          Gratis Offerte
        </a>
        <a href="tel:0653999433" class="border border-white/30 hover:border-white hover:bg-white/5 text-white px-8 py-4 font-semibold rounded text-lg transition-all duration-200 text-center flex items-center justify-center gap-2">
          <Icon name="lucide:phone" class="w-4 h-4" />
          06-53999433
        </a>
      </div>
    </div>
  </section>

  <!-- Beschrijving + Foto -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">{service.naam} in {locatie.naam}</p>
          <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-[#111] uppercase mb-6" style="--delay: 0.1s">
            Uw Specialist In<br />{locatie.naam}
          </h2>
          <p class="reveal-up text-[#555] text-lg leading-relaxed mb-8" style="--delay: 0.15s">
            {service.intro}
          </p>
          <p class="reveal-up text-[#555] leading-relaxed mb-8" style="--delay: 0.2s">
            Als lokale aannemer zijn wij uitstekend bekend in {locatie.naam} en {locatie.regio}. Wij kennen de lokale bouwvoorschriften, werken samen met leveranciers in de buurt en zijn snel ter plaatse. Dat scheelt u tijd en geld.
          </p>
          <div class="reveal-up grid grid-cols-2 gap-4" style="--delay: 0.25s">
            <div class="bg-[#f4f4f4] rounded-xl p-5 text-center">
              <p class="text-2xl font-heading font-bold text-[#111]">500+</p>
              <p class="text-[#777] text-sm mt-1">Projecten</p>
            </div>
            <div class="bg-[#f4f4f4] rounded-xl p-5 text-center">
              <p class="text-2xl font-heading font-bold text-[#111]">9.3</p>
              <p class="text-[#777] text-sm mt-1">Beoordeling</p>
            </div>
          </div>
        </div>
        <div class="reveal-scale">
          <Image src={getImage(service.afbeelding)} alt={`${service.naam} ${locatie.naam}`} class="rounded-xl w-full object-cover aspect-[4/3]" />
        </div>
      </div>
    </div>
  </section>

  <!-- Kenmerken -->
  <section class="py-16 lg:py-24 bg-[#f4f4f4]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Wat wij voor u doen</p>
        <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-[#111] uppercase" style="--delay: 0.1s">
          Onze Aanpak In {locatie.naam}
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {service.kenmerken.map((k, i) => (
          <div class="reveal-up bg-white rounded-xl p-8 flex items-start gap-5" style={`--delay: ${i * 0.06}s`}>
            <div class="w-12 h-12 bg-[#111] rounded-xl flex items-center justify-center shrink-0">
              <Icon name="lucide:check" class="w-5 h-5 text-white" />
            </div>
            <div>
              <p class="text-[#111] font-heading font-bold text-lg uppercase">{k}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Voordelen -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div>
          <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Voordelen</p>
          <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-[#111] uppercase mb-4" style="--delay: 0.1s">
            Waarom Kiezen Voor<br />Projectbouw 010?
          </h2>
          <p class="reveal-up text-[#777] text-lg mb-8" style="--delay: 0.15s">
            Ontdek waarom bewoners in {locatie.naam} kiezen voor Projectbouw 010 als hun aannemer.
          </p>
          <div class="reveal-up flex flex-col sm:flex-row gap-4" style="--delay: 0.2s">
            <a href={`/offerte-aanvragen?bron=/${service.slug}-${locatie.slug}`} class="bg-[#111] text-white px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 text-center hover:bg-[#333]">
              Gratis Offerte
            </a>
          </div>
        </div>
        <div class="space-y-5">
          {service.voordelen.map((v, i) => (
            <div class="reveal-up bg-[#f4f4f4] rounded-xl p-6" style={`--delay: ${(i + 2) * 0.06}s`}>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-[#111] rounded-xl flex items-center justify-center shrink-0 mt-0.5">
                  <span class="text-white font-heading font-bold text-sm">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <div>
                  <h3 class="text-[#111] font-heading font-bold text-lg uppercase mb-1">{v.titel}</h3>
                  <p class="text-[#777] text-sm leading-relaxed">{v.tekst}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Werkwijze -->
  <section class="py-16 lg:py-24 bg-[#111]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="reveal-up text-white/50 font-medium tracking-widest uppercase text-sm mb-3">Hoe het werkt</p>
        <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-white uppercase" style="--delay: 0.1s">Onze Werkwijze</h2>
        <p class="reveal-up text-gray-400 max-w-2xl mx-auto mt-4" style="--delay: 0.15s">
          Van het eerste contact in {locatie.naam} tot de oplevering — wij zorgen voor een soepel en transparant proces.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {werkwijzeStappen.map((step, i) => (
          <div class="reveal-up bg-[#1c1c1c] rounded-xl p-8 relative" style={`--delay: ${i * 0.08}s`}>
            <span class="text-5xl font-heading font-bold text-white/[0.15] absolute top-4 right-6">{step.number}</span>
            <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center mb-5">
              <Icon name={step.icon} class="w-5 h-5 text-white" />
            </div>
            <h3 class="text-white font-heading font-bold text-lg uppercase mb-2">{step.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div>
          <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Veelgestelde vragen</p>
          <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-[#111] uppercase mb-4" style="--delay: 0.1s">
            {service.naam}<br />In {locatie.naam}
          </h2>
          <p class="reveal-up text-[#777] text-lg mb-8" style="--delay: 0.15s">
            Heeft u nog vragen over {service.meervoud} in {locatie.naam}? Neem gerust contact op.
          </p>
          <div class="reveal-up flex flex-col sm:flex-row gap-4" style="--delay: 0.2s">
            <a href="/contact" class="bg-[#111] text-white px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 text-center hover:bg-[#333] flex items-center justify-center gap-2">
              <Icon name="lucide:message-circle" class="w-5 h-5" />
              Stel Uw Vraag
            </a>
          </div>
        </div>
        <div class="space-y-4">
          {faqItems.map((item, i) => (
            <div class="reveal-up" style={`--delay: ${(i + 2) * 0.06}s`}>
              <div class="faq-item border border-[#e0e0e0] rounded-xl">
                <button class="faq-trigger w-full flex items-center justify-between p-6 cursor-pointer hover:bg-[#f4f4f4] transition-colors rounded-xl text-left">
                  <span class="text-[#111] font-semibold text-base pr-4">{item.vraag}</span>
                  <Icon name="lucide:chevron-down" class="faq-icon w-5 h-5 text-[#777] shrink-0 transition-transform duration-300" />
                </button>
                <div class="faq-panel" style="height: 0; overflow: hidden; transition: height 0.3s ease;">
                  <div class="px-6 pb-6 text-[#777] leading-relaxed">
                    {item.antwoord}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- USPs + CTA -->
  <section class="py-16 lg:py-24 bg-[#f4f4f4]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Waarom wij</p>
          <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-[#111] uppercase mb-8" style="--delay: 0.1s">
            Uw Aannemer In {locatie.naam}
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            {[
              { icon: 'lucide:shield-check', title: '4 Jaar Garantie', desc: 'Op al onze werkzaamheden' },
              { icon: 'lucide:clock', title: 'Binnen 24 Uur', desc: 'Reactie op uw aanvraag' },
              { icon: 'lucide:calculator', title: 'All-in Prijzen', desc: 'Geen verborgen kosten' },
              { icon: 'lucide:star', title: '9.3 Beoordeling', desc: '173+ klantreviews' },
            ].map((usp, i) => (
              <div class="reveal-up flex items-start gap-4" style={`--delay: ${(i + 2) * 0.05}s`}>
                <div class="w-10 h-10 bg-[#111] rounded-xl flex items-center justify-center shrink-0">
                  <Icon name={usp.icon} class="w-5 h-5 text-white" />
                </div>
                <div>
                  <p class="text-[#111] font-semibold">{usp.title}</p>
                  <p class="text-[#777] text-sm">{usp.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="reveal-up" style="--delay: 0.3s">
          <div class="bg-[#111] rounded-xl p-10">
            <h3 class="text-white font-heading font-bold text-2xl uppercase mb-3">
              {service.naam} in {locatie.naam}?
            </h3>
            <p class="text-gray-400 mb-8">
              Vraag een gratis en vrijblijvende offerte aan. Wij reageren binnen 24 uur.
            </p>
            <a href={`/offerte-aanvragen?bron=/${service.slug}-${locatie.slug}`} class="block text-center bg-white hover:bg-gray-200 text-[#111] px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 mb-4">
              Offerte Aanvragen
            </a>
            <a href="tel:0653999433" class="block text-center border border-white/20 hover:border-white/50 text-white px-8 py-4 font-semibold rounded text-lg transition-all duration-200">
              <span class="flex items-center justify-center gap-2">
                <Icon name="lucide:phone" class="w-4 h-4" />
                06-53999433
              </span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Offerte Formulier -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div>
          <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Offerte aanvragen</p>
          <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-[#111] uppercase mb-4" style="--delay: 0.1s">
            {service.naam} In<br />{locatie.naam} Nodig?
          </h2>
          <p class="reveal-up text-[#777] text-lg mb-8" style="--delay: 0.15s">
            Vul het formulier in en ontvang binnen 24 uur een vrijblijvende offerte op maat. Geen verborgen kosten.
          </p>
          <div class="reveal-up space-y-5" style="--delay: 0.2s">
            {[
              { icon: 'lucide:badge-check', title: 'Gratis & Vrijblijvend', desc: 'Onze offertes zijn altijd kosteloos en zonder verplichtingen.' },
              { icon: 'lucide:clock', title: 'Reactie Binnen 24 Uur', desc: 'U hoort snel van ons. Wij nemen binnen een werkdag contact op.' },
              { icon: 'lucide:calculator', title: 'All-in Prijzen', desc: 'Geen verborgen kosten. De prijs die u ziet, is de prijs die u betaalt.' },
              { icon: 'lucide:shield-check', title: '4 Jaar Garantie', desc: 'Op al onze werkzaamheden geven wij 4 jaar garantie.' },
            ].map((usp) => (
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-[#f4f4f4] rounded flex items-center justify-center shrink-0 mt-0.5">
                  <Icon name={usp.icon} class="w-4 h-4 text-[#111]" />
                </div>
                <div>
                  <p class="text-[#111] font-medium">{usp.title}</p>
                  <p class="text-[#777] text-sm">{usp.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="reveal-up" style="--delay: 0.2s">
          <form id="offerte-form" class="bg-[#f4f4f4] rounded-xl p-8 space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="naam" class="block text-sm font-medium text-[#333] mb-1.5">Naam *</label>
                <input
                  type="text"
                  id="naam"
                  name="naam"
                  required
                  class="w-full bg-white border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  placeholder="Uw volledige naam"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-[#333] mb-1.5">E-mail *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full bg-white border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  placeholder="uw@email.nl"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="telefoon" class="block text-sm font-medium text-[#333] mb-1.5">Telefoon *</label>
                <input
                  type="tel"
                  id="telefoon"
                  name="telefoon"
                  required
                  class="w-full bg-white border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  placeholder="06-12345678"
                />
              </div>
              <div>
                <label for="woonplaats" class="block text-sm font-medium text-[#333] mb-1.5">Woonplaats</label>
                <input
                  type="text"
                  id="woonplaats"
                  name="woonplaats"
                  class="w-full bg-white border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  value={locatie.naam}
                />
              </div>
            </div>

            <input type="hidden" name="type" value={service.gerelateerdeSlug} />
            <input type="hidden" name="bron" value={`/${service.slug}-${locatie.slug}`} />

            <div>
              <label for="omschrijving" class="block text-sm font-medium text-[#333] mb-1.5">Omschrijving werkzaamheden *</label>
              <textarea
                id="omschrijving"
                name="omschrijving"
                rows="4"
                required
                class="w-full bg-white border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors resize-none"
                placeholder={`Beschrijf uw wensen voor ${service.naam.toLowerCase()}...`}
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                class="mt-1 w-4 h-4 accent-[#111]"
              />
              <label for="privacy" class="text-sm text-[#555]">
                Ik ga akkoord met de verwerking van mijn gegevens voor het behandelen van deze offerte-aanvraag. *
              </label>
            </div>

            <button
              type="submit"
              class="w-full bg-[#111] hover:bg-[#333] text-white px-8 py-4 font-semibold rounded text-lg transition-colors duration-200"
            >
              Verstuur Aanvraag
            </button>

            <div id="form-status" class="hidden rounded p-4 text-sm"></div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Andere diensten in deze locatie -->
  <section class="py-12 bg-[#f4f4f4]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h3 class="reveal-up text-lg font-heading font-bold text-[#111] uppercase mb-4">Meer diensten in {locatie.naam}</h3>
      <div class="flex flex-wrap gap-3">
        {andereDiensten.map((s) => (
          <a
            href={`/${s.slug}-${locatie.slug}`}
            class="bg-[#f4f4f4] hover:bg-[#111] hover:text-white text-[#111] rounded-xl px-5 py-3 text-sm font-medium transition-colors duration-200 border border-[#e0e0e0] hover:border-[#111]"
          >
            {s.naam} {locatie.naam}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.parentElement!;
      const panel = item.querySelector('.faq-panel') as HTMLElement;
      const icon = trigger.querySelector('.faq-icon') as HTMLElement;
      const isOpen = panel.style.height !== '0px' && panel.style.height !== '';

      document.querySelectorAll('.faq-item').forEach((other) => {
        if (other !== item) {
          const otherPanel = other.querySelector('.faq-panel') as HTMLElement;
          const otherIcon = other.querySelector('.faq-icon') as HTMLElement;
          if (otherPanel.style.height !== '0px' && otherPanel.style.height !== '') {
            otherPanel.style.height = otherPanel.scrollHeight + 'px';
            requestAnimationFrame(() => { otherPanel.style.height = '0px'; });
            otherIcon.style.transform = '';
          }
        }
      });

      if (isOpen) {
        panel.style.height = panel.scrollHeight + 'px';
        requestAnimationFrame(() => { panel.style.height = '0px'; });
        icon.style.transform = '';
      } else {
        panel.style.height = panel.scrollHeight + 'px';
        icon.style.transform = 'rotate(180deg)';
        panel.addEventListener('transitionend', () => {
          if (panel.style.height !== '0px') panel.style.height = 'auto';
        }, { once: true });
      }
    });
  });

  // Offerte form handling
  const form = document.getElementById('offerte-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Verzenden...';

      try {
        const res = await fetch('/api/offerte', {
          method: 'POST',
          body: data,
        });

        if (res.ok) {
          status.className = 'rounded p-4 text-sm bg-green-500/10 border border-green-500/30 text-green-700';
          status.textContent = 'Bedankt voor uw aanvraag! Wij nemen binnen 24 uur contact met u op.';
          form.reset();
        } else {
          throw new Error('Server error');
        }
      } catch {
        status.className = 'rounded p-4 text-sm bg-red-500/10 border border-red-500/30 text-red-700';
        status.textContent = 'Er is iets misgegaan. Probeer het opnieuw of neem telefonisch contact op.';
      } finally {
        status.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Verstuur Aanvraag';
      }
    });
  }
</script>
