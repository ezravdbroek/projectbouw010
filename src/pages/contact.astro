---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/**/*.{jpeg,jpg,png}', { eager: true });

function getImage(path: string) {
  const img = images[path];
  if (!img) return path;
  return img.default;
}

const schemaOrg = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Projectbouw 010',
  description: 'Specialist in renovaties en verbouwingen in Rotterdam.',
  url: 'https://projectbouw010.nl',
  telephone: '+31653999433',
  email: 'info@projectbouw010.nl',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Theodoor Colenbranderhof 5',
    addressLocality: 'Rotterdam',
    postalCode: '3059 LS',
    addressCountry: 'NL',
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '07:00',
    closes: '20:00',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '9.3',
    ratingCount: '173',
    bestRating: '10',
  },
});
---

<Layout
  title="Contact | Projectbouw 010 Rotterdam"
  description="Neem contact op met Projectbouw 010 in Rotterdam. Bel, WhatsApp, e-mail of kom langs. Wij reageren binnen 24 uur."
  schemaOrg={schemaOrg}
>
  <!-- Hero — Full width with image -->
  <section class="relative pt-40 pb-24 lg:pt-48 lg:pb-32 overflow-hidden">
    <div class="absolute inset-0">
      <Image src={getImage('/src/assets/images/stukadoor.jpg')} alt="Projectbouw 010 contact" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#111]/60 via-[#111]/70 to-[#111]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="reveal-up flex items-center gap-2 text-sm text-white/50 mb-8">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <span class="text-white">Contact</span>
      </nav>
      <h1 class="reveal-up text-4xl sm:text-5xl lg:text-7xl font-heading font-bold text-white uppercase leading-[0.95]" style="--delay: 0.1s">
        Neem Contact<br />Met Ons Op
      </h1>
      <p class="reveal-up text-gray-300 text-lg sm:text-xl max-w-2xl mt-6 leading-relaxed" style="--delay: 0.2s">
        Heeft u een vraag of wilt u een project bespreken? Wij staan voor u klaar.
      </p>
    </div>
  </section>

  <!-- Contact info + Map side by side -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Contact cards -->
        <div>
          <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Bereik ons</p>
          <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-[#111] uppercase mb-8" style="--delay: 0.1s">
            Contactgegevens
          </h2>

          <div class="space-y-4">
            <a href="tel:0653999433" class="reveal-up flex items-center gap-5 rounded-xl border border-[#e0e0e0] p-6 hover:border-[#111] transition-all duration-300 group" style="--delay: 0.1s">
              <div class="w-14 h-14 bg-[#f4f4f4] rounded-xl flex items-center justify-center shrink-0 group-hover:bg-[#111] transition-colors">
                <Icon name="lucide:phone" class="w-6 h-6 text-[#111] group-hover:text-white transition-colors" />
              </div>
              <div>
                <h3 class="text-[#111] font-heading font-bold text-lg uppercase">Bel Ons Direct</h3>
                <p class="text-[#777]">06-53999433</p>
              </div>
            </a>

            <a href="https://wa.me/31653999433" target="_blank" rel="noopener noreferrer" class="reveal-up flex items-center gap-5 rounded-xl border border-[#e0e0e0] p-6 hover:border-[#111] transition-all duration-300 group" style="--delay: 0.15s">
              <div class="w-14 h-14 bg-[#f4f4f4] rounded-xl flex items-center justify-center shrink-0 group-hover:bg-[#111] transition-colors">
                <Icon name="lucide:message-circle" class="w-6 h-6 text-[#111] group-hover:text-white transition-colors" />
              </div>
              <div>
                <h3 class="text-[#111] font-heading font-bold text-lg uppercase">WhatsApp</h3>
                <p class="text-[#777]">Stuur een bericht</p>
              </div>
            </a>

            <a href="mailto:info@projectbouw010.nl" class="reveal-up flex items-center gap-5 rounded-xl border border-[#e0e0e0] p-6 hover:border-[#111] transition-all duration-300 group" style="--delay: 0.2s">
              <div class="w-14 h-14 bg-[#f4f4f4] rounded-xl flex items-center justify-center shrink-0 group-hover:bg-[#111] transition-colors">
                <Icon name="lucide:mail" class="w-6 h-6 text-[#111] group-hover:text-white transition-colors" />
              </div>
              <div>
                <h3 class="text-[#111] font-heading font-bold text-lg uppercase">E-mail</h3>
                <p class="text-[#777]">info@projectbouw010.nl</p>
              </div>
            </a>

            <div class="reveal-up flex items-center gap-5 rounded-xl border border-[#e0e0e0] p-6" style="--delay: 0.25s">
              <div class="w-14 h-14 bg-[#f4f4f4] rounded-xl flex items-center justify-center shrink-0">
                <Icon name="lucide:map-pin" class="w-6 h-6 text-[#111]" />
              </div>
              <div>
                <h3 class="text-[#111] font-heading font-bold text-lg uppercase">Adres</h3>
                <p class="text-[#777]">Theodoor Colenbranderhof 5<br />3059 LS Rotterdam</p>
              </div>
            </div>

            <div class="reveal-up flex items-center gap-5 rounded-xl border border-[#e0e0e0] p-6" style="--delay: 0.3s">
              <div class="w-14 h-14 bg-[#f4f4f4] rounded-xl flex items-center justify-center shrink-0">
                <Icon name="lucide:clock" class="w-6 h-6 text-[#111]" />
              </div>
              <div>
                <h3 class="text-[#111] font-heading font-bold text-lg uppercase">Bereikbaar</h3>
                <p class="text-[#777]">Ma - Za: 07:00 - 20:00</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="reveal-up" style="--delay: 0.2s">
          <form id="contact-form" class="bg-[#f4f4f4] rounded-xl p-8 space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="naam" class="block text-sm font-medium text-[#333] mb-1.5">Naam *</label>
                <input
                  type="text"
                  id="naam"
                  name="naam"
                  required
                  class="w-full bg-white border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  placeholder="Uw volledige naam"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-[#333] mb-1.5">E-mail *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full bg-white border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  placeholder="uw@email.nl"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="telefoon" class="block text-sm font-medium text-[#333] mb-1.5">Telefoon *</label>
                <input
                  type="tel"
                  id="telefoon"
                  name="telefoon"
                  required
                  class="w-full bg-white border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  placeholder="06-12345678"
                />
              </div>
              <div>
                <label for="onderwerp" class="block text-sm font-medium text-[#333] mb-1.5">Onderwerp</label>
                <input
                  type="text"
                  id="onderwerp"
                  name="onderwerp"
                  class="w-full bg-white border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors"
                  placeholder="Waar gaat uw vraag over?"
                />
              </div>
            </div>

            <div>
              <label for="bericht" class="block text-sm font-medium text-[#333] mb-1.5">Bericht *</label>
              <textarea
                id="bericht"
                name="omschrijving"
                rows="5"
                required
                class="w-full bg-white border border-[#e0e0e0] rounded px-4 py-3 text-[#111] placeholder:text-[#999] focus:outline-none focus:border-[#111] transition-colors resize-none"
                placeholder="Stel uw vraag of beschrijf uw project..."
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                class="mt-1 w-4 h-4 accent-[#111]"
              />
              <label for="privacy" class="text-sm text-[#555]">
                Ik ga akkoord met de verwerking van mijn gegevens voor het behandelen van dit bericht. *
              </label>
            </div>

            <button
              type="submit"
              class="w-full bg-[#111] hover:bg-[#333] text-white px-8 py-4 font-semibold rounded text-lg transition-colors duration-200"
            >
              Verstuur Bericht
            </button>

            <div id="form-status" class="hidden rounded p-4 text-sm"></div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- USPs Row -->
  <section class="py-12 bg-[#f4f4f4]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: 'lucide:shield-check', text: '4 Jaar Garantie' },
          { icon: 'lucide:clock', text: 'Reactie Binnen 24 Uur' },
          { icon: 'lucide:calculator', text: 'All-in Prijzen' },
          { icon: 'lucide:star', text: '9.3 Beoordeling' },
        ].map((usp, i) => (
          <div class="reveal-up flex items-center gap-3" style={`--delay: ${i * 0.05}s`}>
            <div class="w-10 h-10 bg-[#111] rounded-xl flex items-center justify-center shrink-0">
              <Icon name={usp.icon} class="w-5 h-5 text-white" />
            </div>
            <p class="text-[#111] font-semibold text-sm sm:text-base">{usp.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24 bg-[#111]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="reveal-up text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white uppercase mb-4">
            Liever Direct Een Offerte?
          </h2>
          <p class="reveal-up text-gray-400 text-lg mb-8" style="--delay: 0.1s">
            Vul ons offerteformulier in en ontvang binnen 24 uur een vrijblijvende offerte op maat.
          </p>
          <div class="reveal-up flex flex-col sm:flex-row gap-4" style="--delay: 0.2s">
            <a href="/offerte-aanvragen?bron=/contact" class="bg-white text-[#111] px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 text-center hover:bg-gray-200">
              Offerte Aanvragen
            </a>
            <a href="tel:0653999433" class="border border-white/30 hover:border-white hover:bg-white/5 text-white px-8 py-4 font-semibold rounded text-lg transition-all duration-200 text-center flex items-center justify-center gap-2">
              <Icon name="lucide:phone" class="w-4 h-4" />
              06-53999433
            </a>
          </div>
        </div>
        <div class="reveal-up text-center lg:text-left" style="--delay: 0.3s">
          <div class="bg-[#1c1c1c] rounded-xl p-10">
            <div class="grid grid-cols-2 gap-6">
              <div>
                <p class="text-3xl sm:text-4xl font-heading font-bold text-white">500+</p>
                <p class="text-gray-500 text-sm mt-1">Projecten</p>
              </div>
              <div>
                <p class="text-3xl sm:text-4xl font-heading font-bold text-white">9.3</p>
                <p class="text-gray-500 text-sm mt-1">Beoordeling</p>
              </div>
              <div>
                <p class="text-3xl sm:text-4xl font-heading font-bold text-white">15+</p>
                <p class="text-gray-500 text-sm mt-1">Jaar Ervaring</p>
              </div>
              <div>
                <p class="text-3xl sm:text-4xl font-heading font-bold text-white">4 jr</p>
                <p class="text-gray-500 text-sm mt-1">Garantie</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Verzenden...';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          body: data,
        });

        if (res.ok) {
          status.className = 'rounded p-4 text-sm bg-green-500/10 border border-green-500/30 text-green-700';
          status.textContent = 'Bedankt voor uw bericht! Wij nemen binnen 24 uur contact met u op.';
          form.reset();
        } else {
          throw new Error('Server error');
        }
      } catch {
        status.className = 'rounded p-4 text-sm bg-red-500/10 border border-red-500/30 text-red-700';
        status.textContent = 'Er is iets misgegaan. Probeer het opnieuw of neem telefonisch contact op.';
      } finally {
        status.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Verstuur Bericht';
      }
    });
  }
</script>
