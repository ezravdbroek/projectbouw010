---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { projecten } from '../../data/projecten';

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/**/*.{jpeg,jpg,png}', { eager: true });

function getImage(path: string) {
  const img = images[path];
  if (!img) return path;
  return img.default;
}

const categorieen = [...new Set(projecten.map((p) => p.categorie))];
const uitgelicht = projecten.filter((p) => p.uitgelicht);
---

<Layout
  title="Projecten | Projectbouw 010 Rotterdam"
  description="Bekijk onze gerealiseerde projecten. Van badkamerrenovaties tot complete uitbouwen in Rotterdam en omgeving."
>
  <!-- Hero — Full width with image -->
  <section class="relative pt-40 pb-24 lg:pt-48 lg:pb-32 overflow-hidden">
    <div class="absolute inset-0">
      <Image src={getImage('/src/assets/images/badkamer.jpeg')} alt="Projectbouw 010 projecten" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#111]/60 via-[#111]/70 to-[#111]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="reveal-up flex items-center gap-2 text-sm text-white/50 mb-8">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <span class="text-white">Projecten</span>
      </nav>
      <h1 class="reveal-up text-4xl sm:text-5xl lg:text-7xl font-heading font-bold text-white uppercase leading-[0.95]" style="--delay: 0.1s">
        Onze Projecten
      </h1>
      <p class="reveal-up text-gray-300 text-lg sm:text-xl max-w-2xl mt-6 leading-relaxed" style="--delay: 0.2s">
        Bekijk een selectie van onze gerealiseerde projecten in Rotterdam en omgeving. Van badkamerrenovaties tot complete uitbouwen.
      </p>
      <div class="reveal-up flex gap-8 mt-10" style="--delay: 0.3s">
        <div>
          <p class="text-3xl sm:text-4xl font-heading font-bold text-white">500+</p>
          <p class="text-gray-500 text-sm">Projecten</p>
        </div>
        <div>
          <p class="text-3xl sm:text-4xl font-heading font-bold text-white">9.3</p>
          <p class="text-gray-500 text-sm">Beoordeling</p>
        </div>
        <div>
          <p class="text-3xl sm:text-4xl font-heading font-bold text-white">15+</p>
          <p class="text-gray-500 text-sm">Jaar</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Filter & Grid -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
        <div>
          <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Portfolio</p>
          <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-[#111] uppercase" style="--delay: 0.1s">Alle Projecten</h2>
        </div>
        <!-- Filter buttons -->
        <div class="reveal-up flex flex-wrap gap-2" style="--delay: 0.15s">
          <button class="filter-btn active px-4 py-2 rounded text-sm font-medium transition-all duration-200" data-filter="all">
            Alles
          </button>
          {categorieen.map((cat) => (
            <button class="filter-btn px-4 py-2 rounded text-sm font-medium transition-all duration-200" data-filter={cat}>
              {cat}
            </button>
          ))}
        </div>
      </div>

      <!-- Projects grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="projecten-grid">
        {projecten.map((project, i) => (
          <a
            href={`/projecten/${project.slug}`}
            class="reveal-up project-card relative rounded-xl overflow-hidden group aspect-[4/3]"
            data-categorie={project.categorie}
            style={`--delay: ${Math.min(i, 20) * 0.05}s`}
          >
            <Image src={getImage(project.afbeeldingen[0])} alt={project.titel} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#111]/80 via-[#111]/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <span class="text-white/60 text-xs font-medium uppercase tracking-wider">{project.categorie}</span>
              <h3 class="text-white font-heading font-bold text-xl uppercase mt-1">{project.titel}</h3>
              <p class="text-gray-300 text-sm flex items-center gap-1 mt-1">
                <Icon name="lucide:map-pin" class="w-3 h-3" />
                {project.locatie}
              </p>
            </div>
            <div class="absolute top-4 right-4 w-10 h-10 bg-white/10 backdrop-blur-sm rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <Icon name="lucide:arrow-right" class="w-4 h-4 text-white" />
            </div>
          </a>
        ))}
      </div>

      <!-- Toon meer knop -->
      <div class="text-center mt-12" id="toon-meer-wrapper">
        <button id="toon-meer-btn" class="inline-flex items-center gap-2 bg-[#111] text-white px-8 py-4 font-semibold rounded text-base transition-colors duration-200 hover:bg-[#333]">
          Toon Meer Projecten
          <Icon name="lucide:chevron-down" class="w-4 h-4" />
        </button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24 bg-[#111]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="reveal-up text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white uppercase mb-4">
            Uw Project Hier?
          </h2>
          <p class="reveal-up text-gray-400 text-lg mb-8" style="--delay: 0.1s">
            Neem contact met ons op en bespreek de mogelijkheden voor uw renovatie of verbouwing.
          </p>
          <div class="reveal-up flex flex-col sm:flex-row gap-4" style="--delay: 0.2s">
            <a href="/offerte-aanvragen" class="bg-white text-[#111] px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 text-center hover:bg-gray-200">
              Offerte Aanvragen
            </a>
            <a href="tel:0653999433" class="border border-white/30 hover:border-white hover:bg-white/5 text-white px-8 py-4 font-semibold rounded text-lg transition-all duration-200 text-center flex items-center justify-center gap-2">
              <Icon name="lucide:phone" class="w-4 h-4" />
              06-53999433
            </a>
          </div>
        </div>
        <div class="reveal-up hidden lg:block" style="--delay: 0.3s">
          <div class="grid grid-cols-2 gap-4">
            {uitgelicht.slice(0, 2).map((p) => (
              <a href={`/projecten/${p.slug}`} class="relative rounded-xl overflow-hidden group aspect-square">
                <Image src={getImage(p.afbeeldingen[0])} alt={p.titel} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                <div class="absolute inset-0 bg-gradient-to-t from-[#111]/80 to-transparent"></div>
                <div class="absolute bottom-3 left-3 right-3">
                  <p class="text-white font-heading font-bold text-sm uppercase">{p.titel}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .filter-btn {
    background: #f4f4f4;
    color: #777;
    border: 1px solid #e0e0e0;
  }
  .filter-btn:hover,
  .filter-btn.active {
    background: #111111;
    color: #ffffff;
    border-color: #111111;
  }
</style>

<script>
  const INITIAL_LIMIT = 20;
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.project-card') as NodeListOf<HTMLElement>;
  const toonMeerBtn = document.getElementById('toon-meer-btn');
  const toonMeerWrapper = document.getElementById('toon-meer-wrapper');
  let showAll = false;
  let currentFilter = 'all';

  function applyFilter() {
    let visibleCount = 0;
    let totalMatching = 0;

    cards.forEach((card) => {
      const cat = card.getAttribute('data-categorie');
      const matches = currentFilter === 'all' || cat === currentFilter;

      if (matches) {
        totalMatching++;
        if (showAll || visibleCount < INITIAL_LIMIT) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      } else {
        card.style.display = 'none';
      }
    });

    // Show/hide "toon meer" button
    if (toonMeerWrapper) {
      if (!showAll && totalMatching > INITIAL_LIMIT) {
        toonMeerWrapper.style.display = '';
      } else {
        toonMeerWrapper.style.display = 'none';
      }
    }
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.getAttribute('data-filter') || 'all';
      showAll = false;
      applyFilter();
    });
  });

  toonMeerBtn?.addEventListener('click', () => {
    showAll = true;
    applyFilter();
  });

  // Initial apply
  applyFilter();
</script>
