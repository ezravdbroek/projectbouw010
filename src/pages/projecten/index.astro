---
import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { projecten } from '../../data/projecten';

const categorieen = [...new Set(projecten.map((p) => p.categorie))];
---

<Layout
  title="Projecten | Projectbouw 010 Rotterdam"
  description="Bekijk onze gerealiseerde projecten. Van badkamerrenovaties tot complete uitbouwen in Rotterdam en omgeving."
>
  <!-- Hero Banner -->
  <section class="relative pt-32 pb-16 overflow-hidden bg-[#111]">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="reveal-up text-white/60 font-medium tracking-widest uppercase text-sm mb-4">Ons werk</p>
      <h1 class="reveal-up text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-white uppercase" style="--delay: 0.1s">
        Projecten
      </h1>
      <p class="reveal-up text-gray-400 text-lg max-w-xl mt-4" style="--delay: 0.2s">
        Bekijk een selectie van onze gerealiseerde projecten in Rotterdam en omgeving.
      </p>
    </div>
  </section>

  <!-- Filter & Grid -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Filter buttons -->
      <div class="reveal-up flex flex-wrap gap-2 mb-12">
        <button class="filter-btn active px-4 py-2 rounded text-sm font-medium transition-all duration-200" data-filter="all">
          Alles
        </button>
        {categorieen.map((cat) => (
          <button class="filter-btn px-4 py-2 rounded text-sm font-medium transition-all duration-200" data-filter={cat}>
            {cat}
          </button>
        ))}
      </div>

      <!-- Projects grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="projecten-grid">
        {projecten.map((project, i) => (
          <a
            href={`/projecten/${project.slug}`}
            class="reveal-up project-card relative rounded-xl overflow-hidden group aspect-[4/3]"
            data-categorie={project.categorie}
            style={`--delay: ${i * 0.05}s`}
          >
            <img src={project.afbeeldingen[0]} alt={project.titel} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#111]/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
              <span class="text-white/70 text-xs font-medium uppercase tracking-wider">{project.categorie}</span>
              <h3 class="text-white font-heading font-bold text-xl uppercase mt-1">{project.titel}</h3>
              <p class="text-gray-300 text-sm flex items-center gap-1 mt-1">
                <Icon name="lucide:map-pin" class="w-3 h-3" />
                {project.locatie}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20 bg-[#111]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-white uppercase mb-4">Uw project hier?</h2>
      <p class="reveal-up text-gray-400 mb-8 max-w-lg mx-auto" style="--delay: 0.1s">Neem contact met ons op en bespreek de mogelijkheden voor uw renovatie of verbouwing.</p>
      <a href="/offerte-aanvragen" class="reveal-up inline-block bg-white text-[#111] px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 hover:bg-gray-200" style="--delay: 0.2s">
        Offerte Aanvragen
      </a>
    </div>
  </section>
</Layout>

<style>
  .filter-btn {
    background: #f4f4f4;
    color: #777;
    border: 1px solid #e0e0e0;
  }
  .filter-btn:hover,
  .filter-btn.active {
    background: #111111;
    color: #ffffff;
    border-color: #111111;
  }
</style>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.project-card');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.getAttribute('data-filter');
      cards.forEach((card) => {
        const cat = card.getAttribute('data-categorie');
        if (filter === 'all' || cat === filter) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
