---
import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { projecten } from '../../data/projecten';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return projecten.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
};

const { project } = Astro.props;

const andere = projecten.filter((p) => p.slug !== project.slug).slice(0, 3);
---

<Layout
  title={`${project.titel} — ${project.locatie} | Projectbouw 010`}
  description={project.omschrijving}
>
  <!-- Hero — Full width image -->
  <section class="relative pt-40 pb-24 lg:pt-48 lg:pb-32 overflow-hidden">
    <div class="absolute inset-0">
      <img src={project.afbeeldingen[0]} alt={project.titel} class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#111]/60 via-[#111]/70 to-[#111]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="reveal-up flex items-center gap-2 text-sm text-white/50 mb-8">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <a href="/projecten" class="hover:text-white transition-colors">Projecten</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <span class="text-white">{project.titel}</span>
      </nav>
      <span class="reveal-up inline-block bg-white/10 backdrop-blur-sm text-white text-xs font-medium uppercase tracking-wider px-3 py-1 rounded" style="--delay: 0.05s">{project.categorie}</span>
      <h1 class="reveal-up text-4xl sm:text-5xl lg:text-7xl font-heading font-bold text-white uppercase leading-[0.95] mt-4" style="--delay: 0.1s">
        {project.titel}
      </h1>
      <p class="reveal-up text-gray-300 flex items-center gap-2 mt-4 text-lg" style="--delay: 0.2s">
        <Icon name="lucide:map-pin" class="w-4 h-4" />
        {project.locatie}
      </p>
      <div class="reveal-up flex flex-col sm:flex-row gap-4 mt-10" style="--delay: 0.3s">
        <a href="/offerte-aanvragen" class="bg-white text-[#111] px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 text-center hover:bg-gray-200">
          Soortgelijk Project?
        </a>
        <a href="tel:0653999433" class="border border-white/30 hover:border-white hover:bg-white/5 text-white px-8 py-4 font-semibold rounded text-lg transition-all duration-200 text-center flex items-center justify-center gap-2">
          <Icon name="lucide:phone" class="w-4 h-4" />
          06-53999433
        </a>
      </div>
    </div>
  </section>

  <!-- Project Details -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">
        <!-- Content -->
        <div class="lg:col-span-2">
          <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Over dit project</p>
          <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-[#111] uppercase mb-6" style="--delay: 0.1s">
            Projectomschrijving
          </h2>
          <p class="reveal-up text-[#555] text-lg leading-relaxed mb-10" style="--delay: 0.15s">{project.omschrijving}</p>

          <!-- Photo gallery -->
          <div class="space-y-4">
            {project.afbeeldingen.map((img, i) => (
              <div class="reveal-up overflow-hidden rounded-xl" style={`--delay: ${(i + 2) * 0.05}s`}>
                <img src={img} alt={`${project.titel} foto ${i + 1}`} class="w-full object-cover aspect-video" loading="lazy" />
              </div>
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <div>
          <div class="reveal-right sticky top-28 space-y-6" style="--delay: 0.2s">
            <!-- Project info -->
            <div class="rounded-xl border border-[#e0e0e0] p-8">
              <h3 class="text-[#111] font-heading font-bold text-xl uppercase mb-6">Project Details</h3>
              <ul class="space-y-5">
                <li class="flex items-center gap-4">
                  <div class="w-10 h-10 bg-[#f4f4f4] rounded-xl flex items-center justify-center shrink-0">
                    <Icon name="lucide:map-pin" class="w-5 h-5 text-[#111]" />
                  </div>
                  <div>
                    <p class="text-[#777] text-xs uppercase tracking-wider">Locatie</p>
                    <p class="text-[#111] font-medium">{project.locatie}</p>
                  </div>
                </li>
                <li class="flex items-center gap-4">
                  <div class="w-10 h-10 bg-[#f4f4f4] rounded-xl flex items-center justify-center shrink-0">
                    <Icon name="lucide:tag" class="w-5 h-5 text-[#111]" />
                  </div>
                  <div>
                    <p class="text-[#777] text-xs uppercase tracking-wider">Categorie</p>
                    <p class="text-[#111] font-medium">{project.categorie}</p>
                  </div>
                </li>
              </ul>
            </div>

            <!-- CTA -->
            <div class="rounded-xl bg-[#111] p-8">
              <h3 class="text-white font-heading font-bold text-xl uppercase mb-3">
                Soortgelijk Project?
              </h3>
              <p class="text-gray-400 text-sm mb-6">
                Vraag een gratis en vrijblijvende offerte aan. Wij reageren binnen 24 uur.
              </p>
              <a
                href="/offerte-aanvragen"
                class="block text-center bg-white hover:bg-gray-200 text-[#111] px-6 py-3.5 font-semibold rounded transition-colors duration-200 mb-3"
              >
                Offerte Aanvragen
              </a>
              <a
                href="tel:0653999433"
                class="block text-center border border-white/20 hover:border-white/50 text-white px-6 py-3.5 font-semibold rounded transition-all duration-200"
              >
                <span class="flex items-center justify-center gap-2">
                  <Icon name="lucide:phone" class="w-4 h-4" />
                  06-53999433
                </span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- USPs -->
  <section class="py-12 bg-[#f4f4f4]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: 'lucide:shield-check', text: '4 Jaar Garantie' },
          { icon: 'lucide:clock', text: 'Reactie Binnen 24 Uur' },
          { icon: 'lucide:calculator', text: 'All-in Prijzen' },
          { icon: 'lucide:star', text: '9.3 Beoordeling' },
        ].map((usp, i) => (
          <div class="reveal-up flex items-center gap-3" style={`--delay: ${i * 0.05}s`}>
            <div class="w-10 h-10 bg-[#111] rounded-xl flex items-center justify-center shrink-0">
              <Icon name={usp.icon} class="w-5 h-5 text-white" />
            </div>
            <p class="text-[#111] font-semibold text-sm sm:text-base">{usp.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Andere projecten -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8">
        <h2 class="reveal-up text-2xl sm:text-3xl font-heading font-bold text-[#111] uppercase">Andere Projecten</h2>
        <a href="/projecten" class="reveal-up text-[#777] hover:text-[#111] transition-colors text-sm font-medium flex items-center gap-1">
          Alle projecten
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {andere.map((p, i) => (
          <a href={`/projecten/${p.slug}`} class="reveal-up relative rounded-xl overflow-hidden group aspect-[4/3]" style={`--delay: ${i * 0.05}s`}>
            <img src={p.afbeeldingen[0]} alt={p.titel} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#111]/80 via-[#111]/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <span class="text-white/60 text-xs font-medium uppercase tracking-wider">{p.categorie}</span>
              <h3 class="text-white font-heading font-bold text-lg uppercase mt-1">{p.titel}</h3>
              <p class="text-gray-300 text-sm flex items-center gap-1 mt-1">
                <Icon name="lucide:map-pin" class="w-3 h-3" />
                {p.locatie}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
