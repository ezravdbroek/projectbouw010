---
import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { projecten } from '../../data/projecten';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return projecten.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
};

const { project } = Astro.props;

const andere = projecten.filter((p) => p.slug !== project.slug).slice(0, 3);
---

<Layout
  title={`${project.titel} — ${project.locatie} | Projectbouw 010`}
  description={project.omschrijving}
>
  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0">
      <img src={project.afbeeldingen[0]} alt={project.titel} class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#111]/80 to-[#111]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="reveal-up flex items-center gap-2 text-sm text-[#777] mb-8">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <a href="/projecten" class="hover:text-white transition-colors">Projecten</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <span class="text-white">{project.titel}</span>
      </nav>
      <span class="reveal-up text-white/60 text-sm font-medium uppercase tracking-wider">{project.categorie}</span>
      <h1 class="reveal-up text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-white uppercase mt-2" style="--delay: 0.1s">
        {project.titel}
      </h1>
      <p class="reveal-up text-[#777] flex items-center gap-2 mt-4 text-lg" style="--delay: 0.2s">
        <Icon name="lucide:map-pin" class="w-4 h-4" />
        {project.locatie}
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <div class="reveal-up">
            <p class="text-[#333] text-lg leading-relaxed mb-8">{project.omschrijving}</p>
          </div>

          <!-- Photo gallery -->
          <div class="reveal-up grid grid-cols-1 gap-4" style="--delay: 0.1s">
            {project.afbeeldingen.map((img) => (
              <img src={img} alt={project.titel} class="rounded-xl w-full object-cover aspect-video" loading="lazy" />
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <div class="reveal-right" style="--delay: 0.2s">
          <div class="rounded-xl border border-[#e0e0e0] p-8 sticky top-28">
            <h3 class="text-[#111] font-heading font-bold text-xl uppercase mb-4">Project details</h3>
            <ul class="space-y-4 mb-6">
              <li class="flex items-center gap-3">
                <Icon name="lucide:map-pin" class="w-4 h-4 text-[#111] shrink-0" />
                <div>
                  <p class="text-[#777] text-xs">Locatie</p>
                  <p class="text-[#111] text-sm">{project.locatie}</p>
                </div>
              </li>
              <li class="flex items-center gap-3">
                <Icon name="lucide:tag" class="w-4 h-4 text-[#111] shrink-0" />
                <div>
                  <p class="text-[#777] text-xs">Categorie</p>
                  <p class="text-[#111] text-sm">{project.categorie}</p>
                </div>
              </li>
            </ul>

            <hr class="border-[#e0e0e0] my-6" />

            <h4 class="text-[#111] font-medium mb-3">Soortgelijk project?</h4>
            <a
              href="/offerte-aanvragen"
              class="block text-center bg-[#111] hover:bg-[#333] text-white px-6 py-3.5 font-semibold rounded transition-colors duration-200 mb-3"
            >
              Offerte Aanvragen
            </a>
            <a
              href="tel:0653999433"
              class="block text-center border border-[#e0e0e0] hover:border-[#111] text-[#111] px-6 py-3.5 font-semibold rounded transition-all duration-200"
            >
              <span class="flex items-center justify-center gap-2">
                <Icon name="lucide:phone" class="w-4 h-4" />
                06-53999433
              </span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Andere projecten -->
  <section class="py-16 lg:py-20 bg-[#f4f4f4]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="reveal-up text-2xl sm:text-3xl font-heading font-bold text-[#111] uppercase mb-8">Andere Projecten</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {andere.map((p, i) => (
          <a href={`/projecten/${p.slug}`} class="reveal-up relative rounded-xl overflow-hidden group aspect-[4/3]" style={`--delay: ${i * 0.05}s`}>
            <img src={p.afbeeldingen[0]} alt={p.titel} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#111]/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
              <h3 class="text-white font-heading font-bold text-lg uppercase">{p.titel}</h3>
              <p class="text-gray-300 text-sm flex items-center gap-1 mt-1">
                <Icon name="lucide:map-pin" class="w-3 h-3" />
                {p.locatie}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
