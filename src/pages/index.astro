<style>
  /* Project section: tall container for scroll-linked animation on desktop */
  .project-section {
    height: 350vh;
  }
  @media (max-width: 640px) {
    .project-section {
      height: auto;
    }
    .project-section .sticky {
      position: relative;
      height: auto;
    }
    .project-track-container {
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .project-track-container::-webkit-scrollbar {
      display: none;
    }
  }
</style>

<script>
  // Scroll-linked horizontal scroll for projects
  const section = document.querySelector('.project-section') as HTMLElement;
  const track = document.getElementById('project-track') as HTMLElement;

  if (section && track && window.innerWidth > 640) {
    // Calculate max scroll from the last card's right edge
    const lastCard = track.lastElementChild as HTMLElement;
    const trackLeft = track.getBoundingClientRect().left + window.scrollX;
    const lastCardRight = lastCard.offsetLeft + lastCard.offsetWidth + parseInt(getComputedStyle(track).paddingRight || '0');
    const maxScroll = Math.max(0, lastCardRight - window.innerWidth + trackLeft);

    const updateScroll = () => {
      const rect = section.getBoundingClientRect();
      const sectionHeight = section.offsetHeight - window.innerHeight;
      const scrollProgress = Math.max(0, Math.min(1, -rect.top / sectionHeight));
      track.style.transform = `translateX(-${scrollProgress * maxScroll}px)`;
    };

    window.addEventListener('scroll', updateScroll, { passive: true });
    updateScroll();
  }
</script>
