---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout>
  <!-- Hero Section — Split-screen -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none overflow-hidden">
      <span class="text-[12rem] sm:text-[28rem] lg:text-[40rem] font-heading font-bold text-outline leading-none">010</span>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-32 lg:py-0">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-3">
          <p class="reveal-up text-gray-400 font-medium tracking-widest uppercase text-sm mb-4">Renovatie & Verbouwing Rotterdam</p>
          <h1 class="reveal-up text-4xl sm:text-5xl lg:text-7xl font-heading font-bold text-white mb-6 leading-tight" style="--delay: 0.1s">
            Vakmanschap dat<br />staat als een huis.
          </h1>
          <p class="reveal-up text-gray-300 text-lg sm:text-xl max-w-xl mb-10 leading-relaxed" style="--delay: 0.2s">
            Met de jarenlange ervaring van Mike en zijn team is jouw project in vertrouwde handen. Kwaliteit, precisie en veelzijdigheid – dát is Projectbouw010.
          </p>
          <div class="reveal-up flex flex-col sm:flex-row gap-4" style="--delay: 0.3s">
            <a href="/offerte" class="bg-white hover:bg-gray-200 text-primary px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 text-center">
              Offerte Aanvragen
            </a>
            <a href="#projecten" class="border border-white/30 hover:border-white hover:bg-white/5 text-white px-8 py-4 font-semibold rounded text-lg transition-all duration-200 text-center">
              Bekijk Projecten
            </a>
          </div>
        </div>

        <div class="lg:col-span-2 reveal-scale" style="--delay: 0.2s">
          <div class="relative">
            <img src="/images/hero.jpg" alt="Projectbouw 010 - Renovatie werkzaamheden" class="hidden sm:block w-full rounded-2xl object-cover aspect-[3/4] shadow-2xl" loading="eager" />
            <img src="/images/hero-telefoon.jpeg" alt="Projectbouw 010 - Renovatie werkzaamheden" class="sm:hidden w-full rounded-2xl object-cover aspect-[3/4] shadow-2xl" loading="eager" />
            <div class="absolute -inset-3 border border-white/10 rounded-2xl -z-10"></div>
          </div>
        </div>
      </div>

      <!-- Stats strip -->
      <div class="reveal-up mt-16 lg:mt-20 grid grid-cols-3 gap-4 sm:flex sm:flex-wrap sm:justify-start sm:gap-8 lg:gap-16" style="--delay: 0.4s">
        <div>
          <span class="text-2xl sm:text-4xl lg:text-5xl font-heading font-bold text-white block"><span data-count="10">0</span>+</span>
          <span class="text-gray-400 text-xs sm:text-sm">Jaar Ervaring</span>
        </div>
        <div class="w-px h-10 bg-white/10 hidden sm:block self-center"></div>
        <div>
          <span class="text-2xl sm:text-4xl lg:text-5xl font-heading font-bold text-white block"><span data-count="250">0</span>+</span>
          <span class="text-gray-400 text-xs sm:text-sm">Projecten</span>
        </div>
        <div class="w-px h-10 bg-white/10 hidden sm:block self-center"></div>
        <div>
          <span class="text-2xl sm:text-4xl lg:text-5xl font-heading font-bold text-white block">9.3</span>
          <span class="text-gray-400 text-xs sm:text-sm">Trustoo Score</span>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <Icon name="lucide:chevron-down" class="w-6 h-6 text-white/50" />
    </div>
  </section>

  <!-- Diensten Section — Bento Grid -->
  <section id="diensten" class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <p class="reveal-up text-gray-400 font-medium tracking-widest uppercase text-sm mb-3">Wat wij doen</p>
        <h2 class="reveal-up text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white" style="--delay: 0.1s">Onze Diensten</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- Aanbouw & Uitbouw — large -->
        <div class="reveal-scale sm:col-span-2 lg:col-span-2 lg:row-span-2 relative rounded-xl overflow-hidden group cursor-pointer aspect-[4/3] lg:aspect-auto">
          <img src="/images/uitbouw.jpeg" alt="Aanbouw & Uitbouw" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/40 to-transparent"></div>
          <div class="relative h-full flex flex-col justify-end p-6 lg:p-8">
            <h3 class="text-white font-heading font-bold text-2xl lg:text-3xl mb-2">Aanbouw & Uitbouw</h3>
            <p class="text-gray-300 text-sm lg:text-base max-w-sm">Meer ruimte nodig? Wij realiseren uw aanbouw of uitbouw vakkundig en op maat.</p>
          </div>
        </div>

        {[
          { img: '/images/badkamer.jpeg', title: 'Badkamer Renovatie', desc: 'Complete badkamer renovatie met hoogwaardige materialen en modern design.' },
          { img: '/images/keuken.jpeg', title: 'Keukenrenovatie', desc: 'Uw droomkeuken op maat gemaakt. Van ontwerp tot installatie.' },
          { img: '/images/1.jpg', title: 'Stalen Deuren', desc: 'Industriele stalen deuren en kozijnen voor een stijlvolle uitstraling.' },
          { img: '/images/2.jpg', title: 'Stucwerk & Tegelwerk', desc: 'Professioneel stucwerk en tegelwerk voor een perfect afgewerkt resultaat.' },
          { img: '/images/3.jpg', title: 'Traprenovatie', desc: 'Geef uw trap een nieuw leven met onze vakkundige traprenovaties.' },
        ].map((item, i) => (
          <div class="reveal-up relative rounded-xl overflow-hidden group cursor-pointer aspect-[4/3]" style={`--delay: ${(i + 1) * 0.05}s`}>
            <img src={item.img} alt={item.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/40 to-transparent"></div>
            <div class="relative h-full flex flex-col justify-end p-5">
              <h3 class="text-white font-semibold text-lg">{item.title}</h3>
              <p class="text-gray-300 text-xs mt-1 line-clamp-2">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Over Ons Section — Side by side with overlap -->
  <section id="over-ons" class="py-20 lg:py-28 bg-primary-800/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-0 items-center">
        <!-- Text block (overlaps photo on desktop) -->
        <div class="reveal-left lg:relative lg:z-10 lg:-mr-16 order-2 lg:order-1">
          <div class="glass rounded-xl p-8 lg:p-10">
            <p class="text-gray-400 font-medium tracking-widest uppercase text-sm mb-3">Over Projectbouw 010</p>
            <h2 class="text-3xl sm:text-4xl font-heading font-bold text-white mb-6">
              Vakmanschap &<br />Betrouwbaarheid
            </h2>
            <p class="text-gray-300 leading-relaxed mb-4">
              Projectbouw 010, opgericht door Mike, is een aannemersbedrijf gevestigd in Rotterdam. Wij zijn gespecialiseerd in renovaties en verbouwingen voor particulieren. Van een complete badkamerrenovatie tot een stijlvolle uitbouw — wij leveren kwaliteit waar u op kunt vertrouwen.
            </p>
            <p class="text-gray-300 leading-relaxed mb-8">
              Onze aanpak is persoonlijk en transparant. U heeft altijd een vast aanspreekpunt en weet precies waar u aan toe bent. Geen verrassingen, wel een resultaat dat uw verwachtingen overtreft.
            </p>

            <div class="grid grid-cols-3 gap-4">
              <div>
                <p class="text-4xl lg:text-5xl font-heading font-bold text-white"><span data-count="10">0</span>+</p>
                <p class="text-gray-400 text-xs mt-1">Jaar Ervaring</p>
              </div>
              <div>
                <p class="text-4xl lg:text-5xl font-heading font-bold text-white"><span data-count="250">0</span>+</p>
                <p class="text-gray-400 text-xs mt-1">Projecten</p>
              </div>
              <div>
                <p class="text-4xl lg:text-5xl font-heading font-bold text-white">4<span class="text-lg ml-1">jr</span></p>
                <p class="text-gray-400 text-xs mt-1">Garantie</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Photo -->
        <div class="reveal-right order-1 lg:order-2" style="--delay: 0.1s">
          <img src="/images/over.jpeg" alt="Projectbouw 010 op locatie" class="rounded-xl w-full object-cover aspect-[4/3]" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Projecten — Scroll-linked horizontal gallery -->
  <section id="projecten" class="project-section relative">
    <div class="sticky top-0 h-screen flex flex-col justify-center overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8 w-full">
        <div class="flex items-end justify-between">
          <div>
            <p class="text-gray-400 font-medium tracking-widest uppercase text-sm mb-3">Ons werk</p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white">Uitgelichte Projecten</h2>
          </div>
          <a href="/offerte" class="hidden sm:flex items-center gap-2 text-white/70 hover:text-white font-medium hover:gap-3 transition-all">
            Bekijk onze diensten
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </div>
      </div>

      <div class="project-track-container overflow-hidden w-full">
        <div class="flex gap-6 px-4 sm:px-6 lg:px-[max(1.5rem,calc((100vw-80rem)/2+1.5rem))]" id="project-track">
          {[
            { img: '/images/badkamer.jpeg', title: 'Badkamer Renovatie', location: 'Rotterdam-Zuid' },
            { img: '/images/keuken.jpeg', title: 'Keuken Op Maat', location: 'Kralingen' },
            { img: '/images/uitbouw.jpeg', title: 'Complete Uitbouw', location: 'Hillegersberg' },
            { img: '/images/1.jpg', title: 'Stalen Deuren', location: 'Rotterdam-West' },
            { img: '/images/2.jpg', title: 'Stucwerk & Tegelwerk', location: 'Capelle a/d IJssel' },
            { img: '/images/3.jpg', title: 'Traprenovatie', location: 'Schiedam' },
          ].map((project) => (
            <div class="w-[300px] sm:w-[360px] lg:w-[420px] shrink-0 group">
              <div class="rounded-xl overflow-hidden aspect-[3/4] mb-4">
                <img src={project.img} alt={project.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="text-white font-semibold text-lg">{project.title}</h3>
                  <p class="text-gray-400 text-sm flex items-center gap-1 mt-0.5">
                    <Icon name="lucide:map-pin" class="w-3 h-3" />
                    {project.location}
                  </p>
                </div>
                <div class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center group-hover:bg-white group-hover:border-white transition-all duration-300">
                  <Icon name="lucide:arrow-right" class="w-4 h-4 text-white group-hover:text-primary transition-colors" />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Werkwijze — Vertical Timeline -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="reveal-up text-gray-400 font-medium tracking-widest uppercase text-sm mb-3">Hoe wij werken</p>
        <h2 class="reveal-up text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white" style="--delay: 0.1s">Onze Werkwijze</h2>
      </div>

      <div class="relative max-w-4xl mx-auto">
        <div class="absolute left-4 lg:left-1/2 top-0 bottom-0 w-px bg-white/10 lg:-translate-x-px"></div>

        {[
          { number: '01', title: 'Contact', description: 'Neem vrijblijvend contact met ons op. Wij bespreken uw wensen en plannen.' },
          { number: '02', title: 'Offerte', description: 'U ontvangt een duidelijke, all-in offerte zonder verborgen kosten.' },
          { number: '03', title: 'Uitvoering', description: 'Ons vakkundig team gaat aan de slag. U wordt continu op de hoogte gehouden.' },
          { number: '04', title: 'Oplevering', description: 'Samen lopen we het resultaat na. Pas als u tevreden bent, is het project klaar.' },
        ].map((step, i) => (
          <div class={`relative flex items-start gap-8 lg:gap-0 mb-16 last:mb-0 ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'}`}>
            <div class="absolute left-4 lg:left-1/2 w-3 h-3 bg-white rounded-full -translate-x-1.5 lg:-translate-x-1.5 mt-2 z-10"></div>
            <div class={`ml-12 lg:ml-0 lg:w-[45%] ${i % 2 === 0 ? 'lg:pr-16 lg:text-right' : 'lg:pl-16 lg:ml-auto'}`}>
              <div class={`reveal-${i % 2 === 0 ? 'right' : 'left'}`} style={`--delay: ${i * 0.1}s`}>
                <span class="text-6xl lg:text-7xl font-heading font-bold text-outline">{step.number}</span>
                <h3 class="text-white font-heading font-bold text-xl lg:text-2xl mt-2 mb-3">{step.title}</h3>
                <p class="text-gray-400 leading-relaxed">{step.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews — Double Marquee -->
  <section class="py-20 lg:py-28 bg-primary-800/30 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <div class="text-center">
        <p class="reveal-up text-gray-400 font-medium tracking-widest uppercase text-sm mb-3">Klantbeoordelingen</p>
        <h2 class="reveal-up text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-4" style="--delay: 0.1s">Wat Onze Klanten Zeggen</h2>
        <div class="reveal-up flex items-center justify-center gap-3 flex-wrap" style="--delay: 0.2s">
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map(() => (
              <Icon name="lucide:star" class="w-5 h-5 fill-[#FBBC04] text-[#FBBC04]" />
            ))}
          </div>
          <span class="text-white font-semibold text-lg">9.3</span>
          <span class="text-gray-400">gemiddelde score op Trustoo (173 reviews)</span>
        </div>
      </div>
    </div>

    <div class="overflow-hidden mb-4">
      <div class="marquee-track flex gap-4 w-max">
        {[
          { quote: "Ik kan Projectbouw010 alleen maar aanraden. Vakmanschap, betrouwbaarheid en een mooi eindresultaat.", name: "Lisa Aakai", source: "Google Review" },
          { quote: "Projectbouw010 levert netjes en strak werk. Alles werd volgens afspraak uitgevoerd en de communicatie was duidelijk.", name: "Ehab D", source: "Google Review" },
          { quote: "Wat een prachtig resultaat. Dit bedrijf doet er alles aan om haar klanten tevreden te stellen.", name: "Touria Asri", source: "Google Review" },
          { quote: "Great service and excellent results. They delivered exactly what they promised. Finished in two days instead of three.", name: "MJ Saloum", source: "Google Review" },
          { quote: "Ik kan Projectbouw010 alleen maar aanraden. Vakmanschap, betrouwbaarheid en een mooi eindresultaat.", name: "Lisa Aakai", source: "Google Review" },
          { quote: "Projectbouw010 levert netjes en strak werk. Alles werd volgens afspraak uitgevoerd en de communicatie was duidelijk.", name: "Ehab D", source: "Google Review" },
          { quote: "Wat een prachtig resultaat. Dit bedrijf doet er alles aan om haar klanten tevreden te stellen.", name: "Touria Asri", source: "Google Review" },
          { quote: "Great service and excellent results. They delivered exactly what they promised. Finished in two days instead of three.", name: "MJ Saloum", source: "Google Review" },
        ].map((review) => (
          <div class="w-[400px] shrink-0 glass rounded-xl p-6">
            <div class="flex gap-0.5 mb-3">
              {Array.from({ length: 5 }).map(() => (
                <Icon name="lucide:star" class="w-4 h-4 fill-[#FBBC04] text-[#FBBC04]" />
              ))}
            </div>
            <p class="text-white text-sm leading-relaxed mb-4">"{review.quote}"</p>
            <div class="flex items-center gap-2">
              <span class="text-white font-medium text-sm">{review.name}</span>
              <span class="text-gray-500 text-xs">— {review.source}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="overflow-hidden">
      <div class="marquee-track-reverse flex gap-4 w-max">
        {[
          { quote: "Uitstekend vakwerk. Op tijd opgeleverd en zeer betrouwbaar. Complete badkamer, toilet en keuken betegeld.", name: "Roy", source: "Badkamer & Keuken Renovatie" },
          { quote: "TOP bedrijf. Betrouwbaar, snelle communicatie en vakkundig werk. Aanrader voor iedereen die kwaliteit zoekt.", name: "Brain", source: "Renovatie" },
          { quote: "Mike is super vriendelijk, denkt mee in oplossingen, handelt snel en komt zijn afspraken na. Heel professioneel.", name: "Verified Klant", source: "Trustoo Review" },
          { quote: "Groot renovatieproject laten uitvoeren. Huis compleet gestript en netjes opgebouwd. Zeer tevreden met het resultaat.", name: "Verified Klant", source: "Trustoo Review" },
          { quote: "Uitstekend vakwerk. Op tijd opgeleverd en zeer betrouwbaar. Complete badkamer, toilet en keuken betegeld.", name: "Roy", source: "Badkamer & Keuken Renovatie" },
          { quote: "TOP bedrijf. Betrouwbaar, snelle communicatie en vakkundig werk. Aanrader voor iedereen die kwaliteit zoekt.", name: "Brain", source: "Renovatie" },
          { quote: "Mike is super vriendelijk, denkt mee in oplossingen, handelt snel en komt zijn afspraken na. Heel professioneel.", name: "Verified Klant", source: "Trustoo Review" },
          { quote: "Groot renovatieproject laten uitvoeren. Huis compleet gestript en netjes opgebouwd. Zeer tevreden met het resultaat.", name: "Verified Klant", source: "Trustoo Review" },
        ].map((review) => (
          <div class="w-[400px] shrink-0 glass rounded-xl p-6">
            <div class="flex gap-0.5 mb-3">
              {Array.from({ length: 5 }).map(() => (
                <Icon name="lucide:star" class="w-4 h-4 fill-[#FBBC04] text-[#FBBC04]" />
              ))}
            </div>
            <p class="text-white text-sm leading-relaxed mb-4">"{review.quote}"</p>
            <div class="flex items-center gap-2">
              <span class="text-white font-medium text-sm">{review.name}</span>
              <span class="text-gray-500 text-xs">— {review.source}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative py-24 lg:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-white/[0.03]" style="clip-path: polygon(0 8%, 100% 0, 100% 92%, 0 100%)"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div>
          <h2 class="reveal-up text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-6">Klaar Om<br />Te Beginnen?</h2>
          <p class="reveal-up text-gray-300 text-lg mb-10 max-w-lg" style="--delay: 0.1s">Vraag vandaag nog een gratis en vrijblijvende offerte aan. Wij reageren binnen 24 uur.</p>
        </div>
        <div class="reveal-up flex flex-col sm:flex-row gap-4 lg:justify-end" style="--delay: 0.2s">
          <a href="/offerte" class="bg-white hover:bg-gray-200 text-primary px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 text-center">Gratis Offerte Aanvragen</a>
          <a href="tel:0653999433" class="border border-white/30 hover:border-white hover:bg-white/5 text-white px-8 py-4 font-semibold rounded text-lg transition-all duration-200 flex items-center justify-center gap-2">
            <Icon name="lucide:phone" class="w-5 h-5" />
            06-53999433
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="reveal-up text-gray-400 font-medium tracking-widest uppercase text-sm mb-3">Neem contact op</p>
        <h2 class="reveal-up text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-4" style="--delay: 0.1s">Heeft U Een Vraag?</h2>
        <p class="reveal-up text-gray-400 max-w-xl" style="--delay: 0.2s">Neem direct contact op via telefoon, WhatsApp of e-mail. Of vraag een offerte aan via ons formulier.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="tel:0653999433" class="reveal-up glass rounded-xl p-8 hover:bg-white/10 transition-all duration-300 group" style="--delay: 0s">
          <div class="w-14 h-14 bg-white/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-white/20 transition-colors">
            <Icon name="lucide:phone" class="w-6 h-6 text-white" />
          </div>
          <h3 class="text-white font-semibold text-lg mb-1">Bel ons direct</h3>
          <p class="text-gray-400">06-53999433</p>
        </a>

        <a href="https://wa.me/31653999433" target="_blank" rel="noopener noreferrer" class="reveal-up glass rounded-xl p-8 hover:bg-white/10 transition-all duration-300 group" style="--delay: 0.1s">
          <div class="w-14 h-14 bg-white/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-white/20 transition-colors">
            <Icon name="lucide:message-circle" class="w-6 h-6 text-white" />
          </div>
          <h3 class="text-white font-semibold text-lg mb-1">WhatsApp</h3>
          <p class="text-gray-400">Stuur een bericht</p>
        </a>

        <a href="mailto:info@projectbouw010.nl" class="reveal-up glass rounded-xl p-8 hover:bg-white/10 transition-all duration-300 group" style="--delay: 0.2s">
