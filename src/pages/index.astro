<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Werkwijze horizontal pin-scroll (desktop only)
  const werkwijzePin = document.querySelector('.werkwijze-pin') as HTMLElement;
  const werkwijzeTrack = document.getElementById('werkwijze-track') as HTMLElement;

  if (werkwijzePin && werkwijzeTrack && window.innerWidth >= 1024) {
    const totalScroll = werkwijzeTrack.scrollWidth - window.innerWidth;

    gsap.to(werkwijzeTrack, {
      x: -totalScroll,
      ease: 'none',
      scrollTrigger: {
        trigger: werkwijzePin,
        start: 'top top',
        end: () => `+=${totalScroll}`,
        pin: true,
        scrub: 1,
        invalidateOnRefresh: true,
      },
    });
  }
</script>

