---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { diensten } from '../data/diensten';
import { projecten } from '../data/projecten';

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/**/*.{jpeg,jpg,png,webp}', { eager: true });

function getImage(path: string) {
  const img = images[path];
  if (!img) return path;
  return img.default;
}

const uitgelicht = projecten.filter((p) => p.uitgelicht);

const schemaOrg = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'HomeImprovement',
  name: 'Projectbouw 010',
  description: 'Specialist in renovaties en verbouwingen in Rotterdam.',
  url: 'https://projectbouw010.nl',
  telephone: '+31653999433',
  email: 'info@projectbouw010.nl',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Theodoor Colenbranderhof 5',
    addressLocality: 'Rotterdam',
    addressRegion: 'Zuid-Holland',
    addressCountry: 'NL',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '9.3',
    ratingCount: '173',
    bestRating: '10',
  },
});
---

<Layout title="Aannemer Rotterdam | Renovatie & Verbouwing | Projectbouw010" schemaOrg={schemaOrg}>
  <!-- Hero Section — Full viewport video -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Video background -->
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700"
      oncanplay="this.classList.remove('opacity-0')"
    >
      <source src="/images/hero.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-[#111]/70 via-[#111]/50 to-[#111]"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pt-40 lg:pt-48 pb-24">
      <p class="reveal-up text-white/70 font-medium tracking-widest uppercase text-sm mb-6">Renovatie & Verbouwing Rotterdam</p>
      <h1 class="reveal-up text-hero font-heading font-bold text-white uppercase leading-[0.95] mb-8" style="--delay: 0.1s">
        Vakmanschap<br />dat staat als<br />een huis.
      </h1>
      <p class="reveal-up text-gray-300 text-lg sm:text-xl max-w-xl mb-10 leading-relaxed" style="--delay: 0.2s">
        Met 15+ jaar ervaring is jouw project in vertrouwde handen. Kwaliteit, precisie en veelzijdigheid — dat is Projectbouw 010.
      </p>
      <div class="reveal-up flex flex-col sm:flex-row gap-4" style="--delay: 0.3s">
        <a href="/offerte-aanvragen" class="bg-white text-[#111] px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 text-center hover:bg-gray-200">
          Offerte Aanvragen
        </a>
        <a href="/projecten" class="border border-white/30 hover:border-white hover:bg-white/5 text-white px-8 py-4 font-semibold rounded text-lg transition-all duration-200 text-center">
          Bekijk Projecten
        </a>
      </div>

      <!-- Stats strip -->
      <div class="reveal-up mt-16 lg:mt-24 grid grid-cols-2 sm:grid-cols-4 gap-6 sm:gap-8 lg:gap-16 border-t border-white/10 pt-8" style="--delay: 0.4s">
        <div>
          <span class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white block">15+</span>
          <span class="text-[#777] text-sm">Jaar Ervaring</span>
        </div>
        <div>
          <span class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white block">500+</span>
          <span class="text-[#777] text-sm">Projecten</span>
        </div>
        <div>
          <span class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white block">9.3</span>
          <span class="text-[#777] text-sm">Beoordeling</span>
        </div>
        <div>
          <span class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white block">4 <span class="text-lg">jr</span></span>
          <span class="text-[#777] text-sm">Garantie</span>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <Icon name="lucide:chevron-down" class="w-6 h-6 text-white/40" />
    </div>
  </section>

  <!-- Bouw Sectie — 4 expandable panels -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Bouwprojecten</p>
        <h2 class="reveal-up text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-[#111] uppercase" style="--delay: 0.1s">Wat Wij Bouwen</h2>
      </div>

      <!-- Desktop: 4 expandable panels -->
      <div class="hidden lg:flex gap-2 h-[500px] bouw-panels">
        {[
          { naam: 'Aanbouw', slug: 'aanbouw', img: '/src/assets/images/aanbouw.jpg', desc: 'Meer leefruimte nodig? Wij realiseren uw aanbouw vakkundig en op maat.' },
          { naam: 'Uitbouw', slug: 'uitbouw', img: '/src/assets/images/uitbouw.jpeg', desc: 'Vergroot uw woonkamer of keuken met een stijlvolle uitbouw.' },
          { naam: 'Opbouw', slug: 'opbouw', img: '/src/assets/images/opbouw.jpeg', desc: 'Een extra verdieping op uw woning, vakkundig opgebouwd.' },
          { naam: 'Verbouw', slug: 'aanbouw', img: '/src/assets/images/verbouw.jpeg', desc: 'Complete verbouwing van A tot Z, volledig naar uw wensen.' },
        ].map((item, i) => (
          <a
            href={`/diensten/${item.slug}`}
            class="bouw-panel relative rounded-xl overflow-hidden cursor-pointer group"
            style={`--delay: ${i * 0.05}s`}
          >
            <Image src={getImage(item.img)} alt={item.naam} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#111]/90 via-[#111]/40 to-[#111]/10 group-hover:from-[#111]/95 transition-all duration-500"></div>
            <div class="relative h-full flex flex-col justify-end p-8">
              <span class="text-white/40 font-heading font-bold text-6xl absolute top-6 left-8 transition-all duration-500">0{i + 1}</span>
              <h3 class="text-white font-heading font-bold text-2xl uppercase panel-title transition-transform duration-500">{item.naam}</h3>
              <div class="panel-desc transition-all duration-500 overflow-hidden">
                <div class="overflow-hidden">
                  <p class="text-gray-300 text-sm leading-relaxed max-w-xs mt-2">{item.desc}</p>
                  <span class="mt-3 text-white/70 text-sm font-medium flex items-center gap-1">
                    Meer info <Icon name="lucide:arrow-right" class="w-3 h-3" />
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Mobile: vertical cards -->
      <div class="lg:hidden grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          { naam: 'Aanbouw', slug: 'aanbouw', img: '/src/assets/images/aanbouw.jpg' },
          { naam: 'Uitbouw', slug: 'uitbouw', img: '/src/assets/images/uitbouw.jpeg' },
          { naam: 'Opbouw', slug: 'opbouw', img: '/src/assets/images/opbouw.jpeg' },
          { naam: 'Verbouw', slug: 'aanbouw', img: '/src/assets/images/verbouw.jpeg' },
        ].map((item, i) => (
          <a href={`/diensten/${item.slug}`} class="reveal-up relative rounded-xl overflow-hidden group aspect-[16/9]" style={`--delay: ${i * 0.05}s`}>
            <Image src={getImage(item.img)} alt={item.naam} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#111]/80 via-[#111]/30 to-transparent"></div>
            <div class="relative h-full flex items-end p-5">
              <h3 class="text-white font-heading font-bold text-xl uppercase">{item.naam}</h3>
            </div>
          </a>
        ))}
      </div>

      <div class="reveal-up text-center mt-12" style="--delay: 0.3s">
        <a href="/offerte-aanvragen" class="inline-flex items-center gap-2 bg-[#111] text-white px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 hover:bg-[#333]">
          Gratis Offerte Aanvragen
          <Icon name="lucide:arrow-right" class="w-5 h-5" />
        </a>
      </div>
    </div>
  </section>

  <!-- Diensten Section — 2x4 Grid (lichte sectie) -->
  <section id="diensten" class="py-20 lg:py-28 bg-[#f4f4f4]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-16">
        <div>
          <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Onze specialiteiten</p>
          <h2 class="reveal-up text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-[#111] uppercase" style="--delay: 0.1s">Onze Diensten</h2>
        </div>
        <p class="reveal-up hidden sm:block text-[#777] text-sm max-w-xs text-right" style="--delay: 0.2s">
          Van badkamerrenovatie tot stucwerk — wij zijn uw specialist.
        </p>
      </div>

      <!-- 8 diensten in 2x4 grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {diensten
          .filter((d) => ['badkamer-renovatie', 'keukenrenovatie', 'stukadoor', 'tegelzetter', 'cinewall', 'pvc-vloer-leggen', 'toilet-renovatie', 'beton-cire'].includes(d.slug))
          .map((d, i) => (
          <a href={`/diensten/${d.slug}`} class="reveal-up relative rounded-xl overflow-hidden group aspect-[4/3]" style={`--delay: ${i * 0.04}s`}>
            <Image src={getImage(d.afbeelding)} alt={d.naam} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#111]/85 via-[#111]/25 to-transparent group-hover:from-[#111]/95 transition-all duration-300"></div>
            <div class="relative h-full flex items-end p-4 sm:p-5">
              <h3 class="text-white font-heading font-bold text-base sm:text-lg uppercase">{d.naam}</h3>
            </div>
          </a>
        ))}
      </div>

      <!-- Bekijk alle diensten knop -->
      <div class="reveal-up text-center mt-10" style="--delay: 0.3s">
        <a href="/diensten/badkamer-renovatie" class="inline-flex items-center gap-2 bg-[#111] text-white px-8 py-4 font-semibold rounded text-lg transition-colors duration-200 hover:bg-[#333]">
          Bekijk Alle Diensten
          <Icon name="lucide:arrow-right" class="w-5 h-5" />
        </a>
      </div>
    </div>
  </section>

  <!-- Over Ons — Warm section -->
  <section class="py-20 lg:py-28 bg-[#f7f5f0]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Photo -->
        <div class="reveal-left">
          <Image src={getImage('/src/assets/images/badkamer8.jpeg')} alt="Projectbouw 010 op locatie" class="rounded-xl w-full object-cover aspect-[4/3]" />
        </div>

        <!-- Text -->
        <div class="reveal-right" style="--delay: 0.1s">
          <p class="text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Over Projectbouw 010</p>
          <h2 class="text-3xl sm:text-4xl font-heading font-bold text-[#111] uppercase mb-6">
            Vakmanschap &<br />Betrouwbaarheid
          </h2>
          <p class="text-[#333] leading-relaxed mb-4">
            Projectbouw 010, opgericht door Mike Gouri, is een aannemersbedrijf gevestigd in Rotterdam. Wij zijn gespecialiseerd in renovaties en verbouwingen voor particulieren. Van een complete badkamerrenovatie tot een stijlvolle uitbouw — wij leveren kwaliteit waar u op kunt vertrouwen.
          </p>
          <p class="text-[#333] leading-relaxed mb-8">
            Onze aanpak is persoonlijk en transparant. U heeft altijd een vast aanspreekpunt en weet precies waar u aan toe bent. Geen verrassingen, wel een resultaat dat uw verwachtingen overtreft.
          </p>

          <div class="grid grid-cols-3 gap-3 sm:gap-4 mb-8">
            <div>
              <p class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-[#111]">15+</p>
              <p class="text-[#666] text-xs mt-1">Jaar Ervaring</p>
            </div>
            <div>
              <p class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-[#111]">500+</p>
              <p class="text-[#666] text-xs mt-1">Projecten</p>
            </div>
            <div>
              <p class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-[#111]">4<span class="text-lg ml-1">jr</span></p>
              <p class="text-[#666] text-xs mt-1">Garantie</p>
            </div>
          </div>

          <a href="/over-ons" class="inline-flex items-center gap-2 text-[#111] hover:gap-3 font-semibold transition-all duration-200">
            Meer over ons
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Werkwijze — Mobile: vertical with photo bg -->
  <section id="werkwijze-mobile" class="relative py-20 lg:hidden overflow-hidden">
    <Image src={getImage('/src/assets/images/hoe-wij-werken.jpeg')} alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-[#111]/85 backdrop-blur-sm"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <p class="reveal-up text-white/60 font-medium tracking-widest uppercase text-sm mb-3">Hoe wij werken</p>
        <h2 class="reveal-up text-3xl sm:text-4xl font-heading font-bold text-white uppercase" style="--delay: 0.1s">Onze Werkwijze</h2>
      </div>
      <div class="space-y-8">
        {[
          { number: '01', title: 'Contact', icon: 'lucide:phone', description: 'Neem vrijblijvend contact met ons op. Wij bespreken uw wensen en plannen en komen langs voor een opname.' },
          { number: '02', title: 'Offerte', icon: 'lucide:file-text', description: 'U ontvangt een duidelijke, all-in offerte zonder verborgen kosten. Transparant en eerlijk.' },
          { number: '03', title: 'Uitvoering', icon: 'lucide:hammer', description: 'Ons vakkundig team gaat aan de slag. U wordt continu op de hoogte gehouden van de voortgang.' },
          { number: '04', title: 'Oplevering', icon: 'lucide:check-circle', description: 'Samen lopen we het resultaat na. Pas als u tevreden bent, is het project klaar.' },
        ].map((step, i) => (
          <div class="reveal-up flex gap-6" style={`--delay: ${i * 0.1}s`}>
            <div class="shrink-0">
              <span class="text-5xl font-heading font-bold text-white/20">{step.number}</span>
            </div>
            <div>
              <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center mb-3">
                <Icon name={step.icon} class="w-5 h-5 text-white" />
              </div>
              <h3 class="text-white font-heading font-bold text-xl uppercase mb-2">{step.title}</h3>
              <p class="text-gray-300 leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Werkwijze — Desktop: GSAP horizontal pin-scroll with photo bg -->
  <section id="werkwijze" class="hidden lg:block werkwijze-section">
    <div class="relative h-screen flex items-center overflow-hidden werkwijze-pin">
      <Image src={getImage('/src/assets/images/hoe-wij-werken.jpeg')} alt="" class="absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-[#111]/80 backdrop-blur-sm"></div>
      <div class="relative werkwijze-track flex items-center gap-0 w-max" id="werkwijze-track">
        <!-- Title card -->
        <div class="w-screen h-screen flex items-center shrink-0">
          <div class="max-w-7xl mx-auto px-8 w-full">
            <p class="text-white/60 font-medium tracking-widest uppercase text-sm mb-3">Hoe wij werken</p>
            <h2 class="text-5xl lg:text-6xl font-heading font-bold text-white uppercase mb-6">Onze<br />Werkwijze</h2>
            <p class="text-gray-400 max-w-md text-lg">Van eerste contact tot oplevering — wij begeleiden u bij elke stap.</p>
          </div>
        </div>

        {[
          { number: '01', title: 'Contact', icon: 'lucide:phone', description: 'Neem vrijblijvend contact met ons op. Wij bespreken uw wensen en plannen en komen langs voor een opname.' },
          { number: '02', title: 'Offerte', icon: 'lucide:file-text', description: 'U ontvangt een duidelijke, all-in offerte zonder verborgen kosten. Transparant en eerlijk.' },
          { number: '03', title: 'Uitvoering', icon: 'lucide:hammer', description: 'Ons vakkundig team gaat aan de slag. U wordt continu op de hoogte gehouden van de voortgang.' },
          { number: '04', title: 'Oplevering', icon: 'lucide:check-circle', description: 'Samen lopen we het resultaat na. Pas als u tevreden bent, is het project klaar.' },
        ].map((step) => (
          <div class="w-[28vw] h-screen flex items-center shrink-0 px-6">
            <div class="glass rounded-2xl p-10 w-full">
              <span class="text-7xl font-heading font-bold text-white/20 block mb-6">{step.number}</span>
              <div class="w-14 h-14 bg-white/10 rounded-xl flex items-center justify-center mb-6">
                <Icon name={step.icon} class="w-6 h-6 text-white" />
              </div>
              <h3 class="text-white font-heading font-bold text-2xl uppercase mb-4">{step.title}</h3>
              <p class="text-gray-400 leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Projecten — Foto Collage -->
  <section id="projecten" class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="reveal-up text-[#777] font-medium tracking-widest uppercase text-sm mb-3">Ons werk</p>
          <h2 class="reveal-up text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-[#111] uppercase" style="--delay: 0.1s">Recente Projecten</h2>
        </div>
        <a href="/projecten" class="reveal-up hidden sm:flex items-center gap-2 text-[#111] hover:gap-3 font-medium transition-all" style="--delay: 0.2s">
          Alle projecten
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>

      <!-- Collage grid: 3 kolommen, alle cellen gevuld -->
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
        {projecten.slice(0, 6).map((p, i) => (
          <a href={`/projecten/${p.slug}`} class="reveal-up relative rounded-xl overflow-hidden group aspect-[4/3]" style={`--delay: ${i * 0.05}s`}>
            <Image src={getImage(p.afbeeldingen[0])} alt={p.titel} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#111]/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
              <span class="text-white/60 text-xs font-medium uppercase tracking-wider">{p.categorie}</span>
              <h3 class="text-white font-heading font-bold text-lg uppercase mt-1">{p.titel}</h3>
              <p class="text-gray-300 text-xs flex items-center gap-1 mt-0.5">
                <Icon name="lucide:map-pin" class="w-3 h-3" />
                {p.locatie}
              </p>
            </div>
          </a>
        ))}
      </div>

      <a href="/projecten" class="sm:hidden reveal-up inline-flex items-center gap-2 text-[#111] font-medium mt-8">
        Alle projecten
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </section>

  <!-- Team — Ervaring & Expertise -->
  <section class="relative py-24 lg:py-36 bg-[#2a2a2a] overflow-hidden">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-12 gap-4 items-center min-h-[500px] lg:min-h-[650px]">
        <!-- Left photos (3 overlapping, bigger, more to the edge) -->
        <div class="col-span-3 relative hidden lg:block h-[620px]">
          <div class="reveal-left absolute -top-6 -left-8 w-56 rounded-xl overflow-hidden shadow-2xl aspect-[3/4] z-10 rotate-[-4deg]">
            <Image src={getImage('/src/assets/images/1.jpg')} alt="Projectbouw 010 aan het werk" class="w-full h-full object-cover" />
          </div>
          <div class="reveal-left absolute top-1/2 -translate-y-1/2 left-16 w-60 rounded-xl overflow-hidden shadow-2xl aspect-[4/3] z-20 rotate-[2deg]" style="--delay: 0.1s">
            <Image src={getImage('/src/assets/images/badkamer.jpeg')} alt="Badkamer renovatie" class="w-full h-full object-cover" />
          </div>
          <div class="reveal-left absolute -bottom-6 left-0 w-52 rounded-xl overflow-hidden shadow-2xl aspect-[3/4] z-30 rotate-[-2deg]" style="--delay: 0.2s">
            <Image src={getImage('/src/assets/images/2.jpg')} alt="Stucwerk" class="w-full h-full object-cover" />
          </div>
        </div>

        <!-- Center text -->
        <div class="col-span-12 lg:col-span-6 text-center py-8">
          <p class="reveal-up text-white/50 font-medium tracking-widest uppercase text-sm mb-4">Ons team</p>
          <h2 class="reveal-up text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-white uppercase leading-tight mb-8" style="--delay: 0.1s">
            Vakmanschap<br />& Expertise
          </h2>
          <p class="reveal-up text-gray-400 text-lg max-w-lg mx-auto mb-10 leading-relaxed" style="--delay: 0.2s">
            Een vast team van ervaren vakmensen — van tegelzetters en stukadoors tot timmerlieden. Wij werken in eigen beheer, zodat u altijd kunt rekenen op dezelfde kwaliteit en persoonlijke aanpak.
          </p>
          <a href="/over-ons" class="reveal-up inline-block border border-white/30 hover:border-white hover:bg-white/5 text-white px-8 py-4 font-semibold rounded text-lg transition-all duration-200" style="--delay: 0.3s">
            Leer meer over ons
          </a>

          <!-- Mobile: photo row -->
          <div class="lg:hidden grid grid-cols-3 gap-3 mt-12">
