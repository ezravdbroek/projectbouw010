---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import ServiceCard from '../components/ServiceCard.astro';
import ProcessStep from '../components/ProcessStep.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
---

<Layout>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/hero.jpg"
        alt="Projectbouw 010 - Renovatie werkzaamheden"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-primary/80 via-primary/70 to-primary"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-32">
      <p class="fade-in text-gray-400 font-medium tracking-widest uppercase text-sm mb-4">Renovatie & Verbouwing Rotterdam</p>
      <h1 class="fade-in fade-in-delay-1 text-4xl sm:text-5xl lg:text-7xl font-heading font-bold text-white mb-6 leading-tight">
        De Expert In De Bouw
      </h1>
      <p class="fade-in fade-in-delay-2 text-gray-300 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        Projectbouw 010 transformeert uw woning met vakmanschap en oog voor detail. Van complete renovaties tot stijlvolle uitbouwen — wij maken uw droomhuis werkelijkheid.
      </p>
      <div class="fade-in fade-in-delay-3 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/offerte"
          class="bg-white hover:bg-gray-200 text-primary px-8 py-4 font-semibold rounded text-lg transition-colors duration-200"
        >
          Offerte Aanvragen
        </a>
        <a
          href="#projecten"
          class="border border-white/30 hover:border-white hover:bg-white/5 text-white px-8 py-4 font-semibold rounded text-lg transition-all duration-200"
        >
          Bekijk Projecten
        </a>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <Icon name="lucide:chevron-down" class="w-6 h-6 text-white/50" />
    </div>
  </section>

  <!-- Diensten Section -->
  <section id="diensten" class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="fade-in text-gray-400 font-medium tracking-widest uppercase text-sm mb-3">Wat wij doen</p>
        <h2 class="fade-in fade-in-delay-1 text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white">
          Onze Diensten
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <ServiceCard
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>'
          title="Aanbouw & Uitbouw"
          description="Meer ruimte nodig? Wij realiseren uw aanbouw of uitbouw vakkundig en op maat."
          delay={1}
        />
        <ServiceCard
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/></svg>'
          title="Badkamer Renovatie"
          description="Een complete badkamer renovatie met hoogwaardige materialen en modern design."
          delay={2}
        />
        <ServiceCard
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></svg>'
          title="Keukenrenovatie"
          description="Uw droomkeuken op maat gemaakt. Van ontwerp tot installatie, wij regelen het."
          delay={3}
        />
        <ServiceCard
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-4"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>'
          title="Stalen Deuren"
          description="Industriele stalen deuren en kozijnen voor een stijlvolle uitstraling in uw woning."
          delay={1}
        />
        <ServiceCard
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01"/><path d="M17 12h.01"/><path d="M7 12h.01"/></svg>'
          title="Stucwerk & Tegelwerk"
          description="Professioneel stucwerk en tegelwerk voor een perfect afgewerkt resultaat."
          delay={2}
        />
        <ServiceCard
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22V4c0-.5.2-1 .6-1.4C5 2.2 5.5 2 6 2h12c.5 0 1 .2 1.4.6.4.4.6.9.6 1.4v18"/><path d="M10 14v4"/><path d="M14 14v4"/><path d="M10 10h4"/></svg>'
          title="Traprenovatie"
          description="Geef uw trap een nieuw leven met onze vakkundige traprenovaties."
          delay={3}
        />
      </div>
    </div>
  </section>

  <!-- Over Ons Section -->
  <section id="over-ons" class="py-20 lg:py-28 bg-primary-800/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Image -->
        <div class="fade-in relative">
          <img
            src="/images/over.jpg"
            alt="Projectbouw 010 op locatie"
            class="rounded-lg w-full object-cover aspect-[4/3]"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -right-4 bg-white text-primary p-4 rounded-lg hidden sm:block">
            <p class="text-3xl font-heading font-bold">10+</p>
            <p class="text-sm font-semibold">Jaar Ervaring</p>
          </div>
        </div>

        <!-- Content -->
        <div>
          <p class="fade-in text-gray-400 font-medium tracking-widest uppercase text-sm mb-3">Over Projectbouw 010</p>
          <h2 class="fade-in fade-in-delay-1 text-3xl sm:text-4xl font-heading font-bold text-white mb-6">
            Vakmanschap & Betrouwbaarheid
          </h2>
          <p class="fade-in fade-in-delay-2 text-gray-300 leading-relaxed mb-6">
            Projectbouw 010, opgericht door Mike, is een aannemersbedrijf gevestigd in Rotterdam. Wij zijn gespecialiseerd in renovaties en verbouwingen voor particulieren. Van een complete badkamerrenovatie tot een stijlvolle uitbouw — wij leveren kwaliteit waar u op kunt vertrouwen.
          </p>
          <p class="fade-in fade-in-delay-3 text-gray-300 leading-relaxed mb-8">
            Onze aanpak is persoonlijk en transparant. U heeft altijd een vast aanspreekpunt en weet precies waar u aan toe bent. Geen verrassingen, wel een resultaat dat uw verwachtingen overtreft.
          </p>

          <!-- Stats -->
          <div class="fade-in fade-in-delay-4 grid grid-cols-3 gap-6">
            <div class="text-center">
              <p class="text-3xl font-heading font-bold text-white">
                <span data-count="10">0</span>+
              </p>
              <p class="text-gray-400 text-sm mt-1">Jaar Ervaring</p>
            </div>
            <div class="text-center">
              <p class="text-3xl font-heading font-bold text-white">
                <span data-count="250">0</span>+
              </p>
              <p class="text-gray-400 text-sm mt-1">Projecten</p>
            </div>
            <div class="text-center">
              <p class="text-3xl font-heading font-bold text-white">
                4 <span class="text-lg">jaar</span>
              </p>
              <p class="text-gray-400 text-sm mt-1">Garantie</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projecten Showcase -->
  <section id="projecten" class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="fade-in text-gray-400 font-medium tracking-widest uppercase text-sm mb-3">Ons werk</p>
        <h2 class="fade-in fade-in-delay-1 text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white">
          Uitgelichte Projecten
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            img: '/images/badkamer.jpg',
            title: 'Badkamer Renovatie',
            location: 'Rotterdam-Zuid',
          },
          {
            img: '/images/keuken.jpg',
            title: 'Keuken Op Maat',
            location: 'Kralingen',
          },
          {
            img: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=600&q=80',
            title: 'Complete Uitbouw',
            location: 'Hillegersberg',
          },
        ].map((project, i) => (
          <div class={`fade-in fade-in-delay-${i + 1} group relative overflow-hidden rounded-lg aspect-[4/3]`}>
            <img
              src={project.img}
              alt={project.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent opacity-70 group-hover:opacity-90 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
              <h3 class="text-white font-semibold text-lg">{project.title}</h3>
              <p class="text-gray-300 text-sm flex items-center gap-1 mt-1">
                <Icon name="lucide:map-pin" class="w-3 h-3" />
                {project.location}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Werkwijze / Proces -->
  <section class="py-20 lg:py-28 bg-primary-800/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="fade-in text-gray-400 font-medium tracking-widest uppercase text-sm mb-3">Hoe wij werken</p>
        <h2 class="fade-in fade-in-delay-1 text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white">
          Onze Werkwijze
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <ProcessStep
          number={1}
          title="Contact"
          description="Neem vrijblijvend contact met ons op. Wij bespreken uw wensen en plannen."
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>'
          delay={1}
        />
        <ProcessStep
          number={2}
          title="Offerte"
          description="U ontvangt een duidelijke, all-in offerte zonder verborgen kosten."
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>'
          delay={2}
        />
        <ProcessStep
          number={3}
          title="Uitvoering"
          description="Ons vakkundig team gaat aan de slag. U wordt continu op de hoogte gehouden."
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>'
          delay={3}
        />
        <ProcessStep
          number={4}
          title="Oplevering"
          description="Samen lopen we het resultaat na. Pas als u tevreden bent, is het project klaar."
          icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
          delay={4}
        />
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="fade-in text-gray-400 font-medium tracking-widest uppercase text-sm mb-3">Klantbeoordelingen</p>
        <h2 class="fade-in fade-in-delay-1 text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-4">
          Wat Onze Klanten Zeggen
        </h2>
        <div class="fade-in fade-in-delay-2 flex items-center justify-center gap-3 flex-wrap">
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map(() => (
              <Icon name="lucide:star" class="w-5 h-5 fill-[#FBBC04] text-[#FBBC04]" />
            ))}
          </div>
          <span class="text-white font-semibold text-lg">9.3</span>
          <span class="text-gray-400">gemiddelde score op Trustoo (173 reviews)</span>
        </div>
      </div>

      <!-- Auto-scrolling review carousel -->
      <div class="fade-in overflow-hidden" id="review-carousel">
        <div class="flex gap-5 animate-scroll" id="review-track">
          <!-- Set 1 -->
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Ik kan Projectbouw010 alleen maar aanraden. Vakmanschap, betrouwbaarheid en een mooi eindresultaat."
              name="Lisa Aakai"
              project="Google Review"
              stars={5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Projectbouw010 levert netjes en strak werk. Alles werd volgens afspraak uitgevoerd en de communicatie was duidelijk."
              name="Ehab D"
              project="Google Review"
              stars={5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Wat een prachtig resultaat. Dit bedrijf doet er alles aan om haar klanten tevreden te stellen."
              name="Touria Asri"
              project="Google Review"
              stars={5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Great service and excellent results. They delivered exactly what they promised. Finished in two days instead of three."
              name="MJ Saloum"
              project="Google Review"
              stars={5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Uitstekend vakwerk. Op tijd opgeleverd en zeer betrouwbaar. Complete badkamer, toilet en keuken betegeld."
              name="Roy"
              project="Badkamer & Keuken Renovatie"
              stars={4.5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="TOP bedrijf. Betrouwbaar, snelle communicatie en vakkundig werk. Aanrader voor iedereen die kwaliteit zoekt."
              name="Brain"
              project="Renovatie"
              stars={5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Mike is super vriendelijk, denkt mee in oplossingen, handelt snel en komt zijn afspraken na. Heel professioneel."
              name="Verified Klant"
              project="Trustoo Review"
              stars={5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Groot renovatieproject laten uitvoeren. Huis compleet gestript en netjes opgebouwd. Zeer tevreden met het resultaat."
              name="Verified Klant"
              project="Trustoo Review"
              stars={5}
            />
          </div>
          <!-- Duplicated set for seamless loop -->
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Ik kan Projectbouw010 alleen maar aanraden. Vakmanschap, betrouwbaarheid en een mooi eindresultaat."
              name="Lisa Aakai"
              project="Google Review"
              stars={5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Projectbouw010 levert netjes en strak werk. Alles werd volgens afspraak uitgevoerd en de communicatie was duidelijk."
              name="Ehab D"
              project="Google Review"
              stars={5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Wat een prachtig resultaat. Dit bedrijf doet er alles aan om haar klanten tevreden te stellen."
              name="Touria Asri"
              project="Google Review"
              stars={5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Great service and excellent results. They delivered exactly what they promised. Finished in two days instead of three."
              name="MJ Saloum"
              project="Google Review"
              stars={5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Uitstekend vakwerk. Op tijd opgeleverd en zeer betrouwbaar. Complete badkamer, toilet en keuken betegeld."
              name="Roy"
              project="Badkamer & Keuken Renovatie"
              stars={4.5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="TOP bedrijf. Betrouwbaar, snelle communicatie en vakkundig werk. Aanrader voor iedereen die kwaliteit zoekt."
              name="Brain"
              project="Renovatie"
              stars={5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Mike is super vriendelijk, denkt mee in oplossingen, handelt snel en komt zijn afspraken na. Heel professioneel."
              name="Verified Klant"
              project="Trustoo Review"
              stars={5}
            />
          </div>
          <div class="w-[320px] shrink-0">
            <TestimonialCard
              quote="Groot renovatieproject laten uitvoeren. Huis compleet gestript en netjes opgebouwd. Zeer tevreden met het resultaat."
              name="Verified Klant"
              project="Trustoo Review"
              stars={5}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-20 lg:py-24 bg-gradient-to-r from-primary-900 to-primary-800 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,#FFFFFF_1px,transparent_1px)] bg-[length:24px_24px]"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="fade-in text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-6">
        Klaar Om Te Beginnen?
      </h2>
      <p class="fade-in fade-in-delay-1 text-gray-300 text-lg mb-10 max-w-2xl mx-auto">
        Vraag vandaag nog een gratis en vrijblijvende offerte aan. Wij reageren binnen 24 uur.
      </p>
      <div class="fade-in fade-in-delay-2 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/offerte"
          class="bg-white hover:bg-gray-200 text-primary px-8 py-4 font-semibold rounded text-lg transition-colors duration-200"
        >
          Gratis Offerte Aanvragen
        </a>
        <a
          href="tel:0653999433"
          class="border border-white/30 hover:border-white hover:bg-white/5 text-white px-8 py-4 font-semibold rounded text-lg transition-all duration-200 flex items-center justify-center gap-2"
        >
          <Icon name="lucide:phone" class="w-5 h-5" />
          06-53999433
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="fade-in text-gray-400 font-medium tracking-widest uppercase text-sm mb-3">Neem contact op</p>
        <h2 class="fade-in fade-in-delay-1 text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-4">
          Heeft U Een Vraag?
        </h2>
        <p class="fade-in fade-in-delay-2 text-gray-400 max-w-xl mx-auto">
          Vul het formulier in en wij nemen zo snel mogelijk contact met u op. Of neem direct contact op via telefoon of WhatsApp.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">
        <!-- Form -->
        <div class="lg:col-span-3">
          <form class="fade-in bg-white/5 border border-white/10 rounded-xl p-6 sm:p-8 space-y-5" id="contact-form">
