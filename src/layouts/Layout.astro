---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  schemaOrg?: string;
}

const {
  title = 'Aannemer Rotterdam | Renovatie & Verbouwing | Projectbouw010',
  description = 'Projectbouw 010 is uw specialist in renovaties en verbouwingen in Rotterdam. Vakmanschap, betrouwbaarheid en persoonlijke aanpak.',
  canonicalUrl,
  schemaOrg,
} = Astro.props;
---

<!doctype html>
<html lang="nl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Google Fonts: Oswald + Source Sans 3 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@600;700&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:site_name" content="Projectbouw 010" />

    {schemaOrg && <script type="application/ld+json" set:html={schemaOrg} />}
  </head>
  <body class="bg-white text-[#111111] font-sans antialiased">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieConsent />

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // GSAP reveal animations
      const revealElements = document.querySelectorAll('.reveal-up, .reveal-left, .reveal-right, .reveal-scale, .fade-in');
      revealElements.forEach((el) => {
        const htmlEl = el as HTMLElement;
        const delay = parseFloat(htmlEl.style.getPropertyValue('--delay') || '0');

        let fromVars: gsap.TweenVars = { opacity: 0 };
        if (el.classList.contains('reveal-up') || el.classList.contains('fade-in')) {
          fromVars.y = 40;
        } else if (el.classList.contains('reveal-left')) {
          fromVars.x = -40;
        } else if (el.classList.contains('reveal-right')) {
          fromVars.x = 40;
        } else if (el.classList.contains('reveal-scale')) {
          fromVars.scale = 0.92;
        }

        gsap.from(htmlEl, {
          ...fromVars,
          duration: 0.8,
          delay,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: htmlEl,
            start: 'top 88%',
            once: true,
          },
        });
      });

      // Counter animation for stats
      document.querySelectorAll('[data-count]').forEach((el) => {
        const target = parseInt(el.getAttribute('data-count') || '0', 10);
        const obj = { val: 0 };

        ScrollTrigger.create({
          trigger: el,
          start: 'top 90%',
          once: true,
          onEnter: () => {
            gsap.to(obj, {
              val: target,
              duration: 1.5,
              ease: 'power2.out',
              onUpdate: () => {
                (el as HTMLElement).textContent = Math.round(obj.val).toString();
              },
            });
          },
        });
      });

      // Pause marquee on hover
      document.querySelectorAll('.marquee-track, .marquee-track-reverse').forEach((track) => {
        const parent = track.parentElement;
        if (parent) {
          parent.addEventListener('mouseenter', () => {
            (track as HTMLElement).style.animationPlayState = 'paused';
          });
          parent.addEventListener('mouseleave', () => {
            (track as HTMLElement).style.animationPlayState = 'running';
          });
        }
      });
    </script>

    <style is:global>
      /* Prevent horizontal overflow without breaking sticky */
      html, body {
        overflow-x: clip;
      }

      /* Reduced motion: disable animations */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }

      /* Glassmorphism utility */
      .glass {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      /* Outlined text utility */
      .text-outline {
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.08);
        -webkit-text-fill-color: transparent;
        color: transparent;
      }
      .text-outline-dark {
        -webkit-text-stroke: 1px rgba(17, 17, 17, 0.12);
        -webkit-text-fill-color: transparent;
        color: transparent;
      }

      /* Marquee animation */
      .marquee-track {
        animation: marquee 40s linear infinite;
      }
      .marquee-track-reverse {
        animation: marqueeReverse 40s linear infinite;
      }

      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      @keyframes marqueeReverse {
        0% { transform: translateX(-50%); }
        100% { transform: translateX(0); }
      }

    </style>
  </body>
</html>
