---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { diensten } from '../data/diensten';
import logoImg from '../assets/images/logo.png';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Over Ons', href: '/over-ons' },
  { label: 'Projecten', href: '/projecten' },
  { label: 'Contact', href: '/contact' },
];

const bouwLinks = [
  { naam: 'Verbouw', slug: 'aanbouw' },
  ...diensten.filter((d) => ['aanbouw', 'uitbouw', 'opbouw'].includes(d.slug)),
];
const overigeDiensten = diensten.filter((d) => !['aanbouw', 'uitbouw', 'opbouw'].includes(d.slug));
---

<!-- Top Bar (desktop only) -->
<div id="topbar" class="max-lg:hidden fixed top-0 left-0 w-full z-[60] bg-[#0a0a0a] border-b border-white/10 text-sm transition-transform duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-10">
    <div class="flex items-center gap-4">
      <a href="tel:0653999433" class="flex items-center gap-2 text-gray-400 hover:text-white transition-colors">
        <Icon name="lucide:phone" class="w-3.5 h-3.5" />
        06-53999433
      </a>
      <span class="text-white/20">|</span>
      <a href="mailto:info@projectbouw010.nl" class="text-gray-400 hover:text-white transition-colors">
        info@projectbouw010.nl
      </a>
    </div>
    <div class="flex items-center gap-4">
      <a href="https://wa.me/31653999433" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="WhatsApp">
        <Icon name="lucide:message-circle" class="w-4 h-4" />
      </a>
      <a href="https://www.instagram.com/projectbouw010" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Instagram">
        <Icon name="lucide:instagram" class="w-4 h-4" />
      </a>
      <a href="https://www.facebook.com/projectbouw010" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Facebook">
        <Icon name="lucide:facebook" class="w-4 h-4" />
      </a>
    </div>
  </div>
</div>

<!-- Main Navbar -->
<header id="navbar" class="fixed top-0 left-0 w-full z-[70] transition-all duration-300 lg:top-10">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <Image src={logoImg} alt="Projectbouw 010" class="h-10 w-auto" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-8">
        <a href="/" class="nav-link text-base font-semibold text-gray-300 hover:text-white transition-colors duration-200 relative">
          Home
        </a>

        <!-- Diensten with hover dropdown -->
        <div class="relative" id="diensten-desktop">
          <button
            class="nav-link text-base font-semibold text-gray-300 hover:text-white transition-colors duration-200 flex items-center gap-1 relative"
            id="diensten-desktop-trigger"
          >
            Diensten
            <Icon name="lucide:chevron-down" class="w-3.5 h-3.5 transition-transform duration-300" id="diensten-desktop-chevron" />
          </button>
        </div>

        {navLinks.slice(1).map((link) => (
          <a href={link.href} class="nav-link text-base font-semibold text-gray-300 hover:text-white transition-colors duration-200 relative">
            {link.label}
          </a>
        ))}
        <a href="/offerte-aanvragen" class="bg-white text-[#111] px-6 py-2.5 text-base font-bold rounded transition-colors duration-200 hover:bg-gray-200">
          Offerte Aanvragen
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="menu-toggle"
        class="lg:hidden relative w-10 h-10 flex items-center justify-center"
        aria-label="Menu openen"
        aria-expanded="false"
      >
        <span class="absolute w-6 h-0.5 bg-white transition-all duration-300" id="bar1" style="transform: translateY(-6px)"></span>
        <span class="absolute w-6 h-0.5 bg-white transition-all duration-300" id="bar2"></span>
        <span class="absolute w-6 h-0.5 bg-white transition-all duration-300" id="bar3" style="transform: translateY(6px)"></span>
      </button>
    </div>
  </nav>

  <!-- Full-width Diensten dropdown panel (desktop, animated) -->
  <div id="diensten-dropdown" class="w-full bg-[#111]/95 backdrop-blur-md border-t border-white/10 overflow-hidden transition-all duration-300 ease-in-out" style="max-height: 0; opacity: 0;">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex gap-12">
        <ul class="space-y-4 border-r border-white/10 pr-12">
          {bouwLinks.map((d) => (
            <li>
              <a href={`/diensten/${d.slug}`} class="text-white hover:text-gray-300 transition-colors duration-200 text-xl font-heading font-bold uppercase block">
                {d.naam}
              </a>
            </li>
          ))}
        </ul>
        <div class="grid grid-cols-2 gap-x-12 gap-y-4 flex-1">
          {overigeDiensten.map((d) => (
            <a href={`/diensten/${d.slug}`} class="text-gray-300 hover:text-white transition-colors duration-200 text-base block">
              {d.naam}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu (outside header, full screen overlay) -->
<div id="mobile-menu" class="lg:hidden fixed inset-0 z-[65] bg-[#111] hidden" style="-webkit-overflow-scrolling: touch;">
  <!-- Hoofdmenu -->
  <div id="mobile-main-panel" class="overflow-y-auto h-full pt-24 pb-10 px-6 transition-transform duration-300">
    <div class="space-y-2">
      <a href="/" class="block py-4 text-white text-2xl font-heading font-bold uppercase border-b border-white/10">
        Home
      </a>

      <!-- Diensten -> opent subpaneel -->
      <div class="border-b border-white/10">
        <button
          id="diensten-mobile-toggle"
          class="w-full flex items-center justify-between py-4 text-white text-2xl font-heading font-bold uppercase"
        >
          <span>Diensten</span>
          <Icon name="lucide:chevron-right" class="w-5 h-5" />
        </button>
      </div>

      {navLinks.slice(1).map((link) => (
        <a href={link.href} class="block py-4 text-white text-2xl font-heading font-bold uppercase border-b border-white/10">
          {link.label}
        </a>
      ))}
    </div>

    <div class="mt-10 space-y-4">
      <a href="/offerte-aanvragen" class="block text-center bg-white text-[#111] px-6 py-4 text-lg font-bold rounded transition-colors duration-200 hover:bg-gray-200">
        Offerte Aanvragen
      </a>
      <a href="tel:0653999433" class="block text-center border border-white/30 text-white px-6 py-4 text-lg font-semibold rounded transition-all duration-200 hover:border-white">
        <span class="flex items-center justify-center gap-2">
          <Icon name="lucide:phone" class="w-4 h-4" />
          06-53999433
        </span>
      </a>
    </div>

    <div class="mt-10 flex items-center justify-center gap-6">
      <a href="https://wa.me/31653999433" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="WhatsApp">
        <Icon name="lucide:message-circle" class="w-6 h-6" />
      </a>
      <a href="https://www.instagram.com/projectbouw010" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Instagram">
        <Icon name="lucide:instagram" class="w-6 h-6" />
      </a>
      <a href="https://www.facebook.com/projectbouw010" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Facebook">
        <Icon name="lucide:facebook" class="w-6 h-6" />
      </a>
    </div>
  </div>

  <!-- Diensten subpaneel -->
  <div id="mobile-diensten-panel" class="absolute inset-0 overflow-y-auto h-full pt-24 pb-10 px-6 bg-[#111] transition-transform duration-300 translate-x-full">
    <button
      id="diensten-mobile-back"
      class="flex items-center gap-2 text-gray-400 hover:text-white transition-colors mb-6"
    >
      <Icon name="lucide:chevron-left" class="w-5 h-5" />
      <span class="text-base font-medium">Terug</span>
    </button>
    <p class="text-white/50 font-medium tracking-widest uppercase text-xs mb-4">Diensten</p>

    <div class="space-y-1">
      {bouwLinks.map((d) => (
        <a
          href={`/diensten/${d.slug}`}
          class="block py-3 text-white font-heading font-bold text-xl uppercase hover:text-gray-300 transition-colors duration-200 border-b border-white/10"
        >
          {d.naam}
        </a>
      ))}
    </div>

    <div class="space-y-1 mt-2">
      {overigeDiensten.map((d) => (
        <a
          href={`/diensten/${d.slug}`}
          class="block py-3 text-gray-300 hover:text-white transition-colors duration-200 text-base border-b border-white/5"
        >
          {d.naam}
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  const navbar = document.getElementById('navbar')!;
  const menuToggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;
  let menuOpen = false;
  const topbar = document.getElementById('topbar');

  // Scroll: transparent -> solid + hide topbar
  function updateNavbar() {
    const dd = document.getElementById('diensten-dropdown');
    const dropdownIsOpen = dd ? (dd.style.maxHeight !== '0' && dd.style.maxHeight !== '0px' && dd.style.maxHeight !== '') : false;
    if (window.scrollY > 50 || menuOpen || dropdownIsOpen) {
      navbar.classList.add('bg-[#111]/95', 'backdrop-blur-md', 'shadow-lg');
      navbar.classList.remove('lg:top-10');
      navbar.classList.add('lg:top-0');
      if (topbar) topbar.style.transform = 'translateY(-100%)';
    } else {
      navbar.classList.remove('bg-[#111]/95', 'backdrop-blur-md', 'shadow-lg');
      navbar.classList.remove('lg:top-0');
      navbar.classList.add('lg:top-10');
      if (topbar) topbar.style.transform = '';
    }
  }
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  // Mobile menu toggle
  menuToggle.addEventListener('click', () => {
    menuOpen = !menuOpen;
    mobileMenu.classList.toggle('hidden');
    menuToggle.setAttribute('aria-expanded', menuOpen.toString());

    if (menuOpen) {
      bar1.style.transform = 'rotate(45deg)';
      bar2.style.opacity = '0';
      bar3.style.transform = 'rotate(-45deg)';
      document.body.style.overflow = 'hidden';
    } else {
      bar1.style.transform = 'translateY(-6px)';
      bar2.style.opacity = '1';
      bar3.style.transform = 'translateY(6px)';
      document.body.style.overflow = '';
      // Reset diensten subpaneel
      const mp = document.getElementById('mobile-main-panel');
      const dp = document.getElementById('mobile-diensten-panel');
      if (mp && dp) {
        mp.style.transform = '';
        dp.style.transform = '';
      }
    }
    updateNavbar();
  });

  // Close mobile menu on link click
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false;
      mobileMenu.classList.add('hidden');
      menuToggle.setAttribute('aria-expanded', 'false');
      bar1.style.transform = 'translateY(-6px)';
      bar2.style.opacity = '1';
      bar3.style.transform = 'translateY(6px)';
      document.body.style.overflow = '';
      updateNavbar();
    });
  });

  // Desktop diensten dropdown
  const dienstenTrigger = document.getElementById('diensten-desktop-trigger');
  const dienstenDesktop = document.getElementById('diensten-desktop');
  const dienstenDropdown = document.getElementById('diensten-dropdown');
  const dienstenDesktopChevron = document.getElementById('diensten-desktop-chevron');
  let dropdownOpen = false;
  let closeTimeout: ReturnType<typeof setTimeout> | null = null;

  function openDropdown() {
    if (closeTimeout) { clearTimeout(closeTimeout); closeTimeout = null; }
    if (dropdownOpen) return;
    dropdownOpen = true;
    dienstenDropdown!.style.maxHeight = dienstenDropdown!.scrollHeight + 'px';
    dienstenDropdown!.style.opacity = '1';
    dienstenDesktopChevron!.style.transform = 'rotate(180deg)';
    navbar.classList.add('bg-[#111]/95', 'backdrop-blur-md', 'shadow-lg');
  }

  function closeDropdown() {
    closeTimeout = setTimeout(() => {
      dropdownOpen = false;
      dienstenDropdown!.style.maxHeight = '0';
      dienstenDropdown!.style.opacity = '0';
      dienstenDesktopChevron!.style.transform = '';
      updateNavbar();
    }, 150);
  }

  if (dienstenTrigger && dienstenDesktop && dienstenDropdown && dienstenDesktopChevron) {
    dienstenDesktop.addEventListener('mouseenter', openDropdown);
    dienstenDesktop.addEventListener('mouseleave', closeDropdown);
    dienstenDropdown.addEventListener('mouseenter', openDropdown);
    dienstenDropdown.addEventListener('mouseleave', closeDropdown);

    dienstenDropdown.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        dropdownOpen = false;
        dienstenDropdown.style.maxHeight = '0';
        dienstenDropdown.style.opacity = '0';
        dienstenDesktopChevron.style.transform = '';
        updateNavbar();
      });
    });
  }

  // Mobile diensten sub-panel
  const dienstenToggle = document.getElementById('diensten-mobile-toggle');
  const mainPanel = document.getElementById('mobile-main-panel');
  const dienstenPanel = document.getElementById('mobile-diensten-panel');
  const dienstenBack = document.getElementById('diensten-mobile-back');

  if (dienstenToggle && mainPanel && dienstenPanel && dienstenBack) {
    dienstenToggle.addEventListener('click', () => {
      mainPanel.style.transform = 'translateX(-100%)';
      dienstenPanel.style.transform = 'translateX(0)';
    });

    dienstenBack.addEventListener('click', () => {
      mainPanel.style.transform = '';
      dienstenPanel.style.transform = '';
    });
  }
</script>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: #ffffff;
    transition: width 0.3s ease;
  }
  .nav-link:hover::after {
    width: 100%;
  }
</style>
