---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Diensten', href: '/#diensten' },
  { label: 'Over Ons', href: '/#over-ons' },
  { label: 'Projecten', href: '/#projecten' },
  { label: 'Contact', href: '/#contact' },
];
---

<header id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <img src="/images/logo.png" alt="Projectbouw 010" class="h-10 w-auto" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-gray-300 hover:text-white transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
        <a
          href="/offerte"
          class="bg-white hover:bg-gray-200 text-primary px-6 py-2.5 text-sm font-semibold rounded transition-colors duration-200"
        >
          Offerte Aanvragen
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="menu-toggle"
        class="lg:hidden flex flex-col gap-1.5 p-2"
        aria-label="Menu openen"
        aria-expanded="false"
      >
        <span class="block w-6 h-0.5 bg-white transition-all duration-300 origin-center" id="bar1"></span>
        <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar2"></span>
        <span class="block w-6 h-0.5 bg-white transition-all duration-300 origin-center" id="bar3"></span>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="lg:hidden hidden">
      <div class="py-4 space-y-1 border-t border-white/10">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="block px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
        <div class="px-4 pt-3">
          <a
            href="/offerte"
            class="block text-center bg-white hover:bg-gray-200 text-primary px-6 py-3 font-semibold rounded transition-colors duration-200"
          >
            Offerte Aanvragen
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const menuToggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;
  let menuOpen = false;

  // Scroll: transparent → solid
  function updateNavbar() {
    if (window.scrollY > 50 || menuOpen) {
      navbar.classList.add('bg-primary/95', 'backdrop-blur-md', 'shadow-lg');
    } else {
      navbar.classList.remove('bg-primary/95', 'backdrop-blur-md', 'shadow-lg');
    }
  }
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  // Mobile menu toggle
  menuToggle.addEventListener('click', () => {
    menuOpen = !menuOpen;
    mobileMenu.classList.toggle('hidden');
    menuToggle.setAttribute('aria-expanded', menuOpen.toString());

    if (menuOpen) {
      bar1.style.transform = 'rotate(45deg) translate(3px, 3px)';
      bar2.style.opacity = '0';
      bar3.style.transform = 'rotate(-45deg) translate(3px, -3px)';
    } else {
      bar1.style.transform = '';
      bar2.style.opacity = '';
      bar3.style.transform = '';
    }
    updateNavbar();
  });

  // Close mobile menu on link click
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false;
      mobileMenu.classList.add('hidden');
      menuToggle.setAttribute('aria-expanded', 'false');
      bar1.style.transform = '';
      bar2.style.opacity = '';
      bar3.style.transform = '';
      updateNavbar();
    });
  });
</script>
