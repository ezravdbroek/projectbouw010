---
import { Icon } from 'astro-icon/components';
import { diensten } from '../data/diensten';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Over Ons', href: '/over-ons' },
  { label: 'Projecten', href: '/projecten' },
  { label: 'Contact', href: '/contact' },
];

const dienstenColumns = [
  diensten.filter((_, i) => i < 5),
  diensten.filter((_, i) => i >= 5 && i < 10),
  diensten.filter((_, i) => i >= 10),
];
---

<header id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <img src="/images/logo.png" alt="Projectbouw 010" class="h-10 w-auto" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-8">
        <a
          href="/"
          class="nav-link text-base font-medium text-gray-300 hover:text-white transition-colors duration-200 relative"
        >
          Home
        </a>

        <!-- Diensten with hover dropdown -->
        <div class="relative" id="diensten-desktop">
          <button
            class="nav-link text-base font-medium text-gray-300 hover:text-white transition-colors duration-200 flex items-center gap-1 relative"
            id="diensten-desktop-trigger"
          >
            Diensten
            <Icon name="lucide:chevron-down" class="w-3.5 h-3.5 transition-transform duration-300" id="diensten-desktop-chevron" />
          </button>
        </div>

        {navLinks.slice(1).map((link) => (
          <a
            href={link.href}
            class="nav-link text-base font-medium text-gray-300 hover:text-white transition-colors duration-200 relative"
          >
            {link.label}
          </a>
        ))}
        <a
          href="/offerte-aanvragen"
          class="bg-white text-[#111] px-6 py-2.5 text-base font-semibold rounded transition-colors duration-200 hover:bg-gray-200"
        >
          Offerte Aanvragen
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="menu-toggle"
        class="lg:hidden relative w-10 h-10 flex items-center justify-center"
        aria-label="Menu openen"
        aria-expanded="false"
      >
        <span class="absolute w-6 h-0.5 bg-white transition-all duration-300" id="bar1" style="transform: translateY(-6px)"></span>
        <span class="absolute w-6 h-0.5 bg-white transition-all duration-300" id="bar2"></span>
        <span class="absolute w-6 h-0.5 bg-white transition-all duration-300" id="bar3" style="transform: translateY(6px)"></span>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="lg:hidden hidden max-h-[calc(100vh-5rem)] overflow-y-auto">
      <div class="py-4 space-y-1 border-t border-white/10">
        <a
          href="/"
          class="block px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded transition-colors duration-200"
        >
          Home
        </a>

        <!-- Mobile Diensten accordion -->
        <div>
          <button
            id="diensten-mobile-toggle"
            class="w-full flex items-center justify-between px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded transition-colors duration-200"
          >
            <span>Diensten</span>
            <Icon name="lucide:chevron-down" class="w-4 h-4 transition-transform duration-200" id="diensten-chevron" />
          </button>
          <div id="diensten-mobile-list" class="hidden pl-4">
            {diensten.map((d) => (
              <a
                href={`/diensten/${d.slug}`}
                class="block px-4 py-2 text-gray-400 hover:text-white text-sm transition-colors duration-200"
              >
                {d.naam}
              </a>
            ))}
          </div>
        </div>

        {navLinks.slice(1).map((link) => (
          <a
            href={link.href}
            class="block px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
        <div class="px-4 pt-3">
          <a
            href="/offerte-aanvragen"
            class="block text-center bg-white text-[#111] px-6 py-3 font-semibold rounded transition-colors duration-200 hover:bg-gray-200"
          >
            Offerte Aanvragen
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Full-width Diensten dropdown panel (animated) -->
  <div id="diensten-dropdown" class="w-full bg-[#111]/95 backdrop-blur-md border-t border-white/10 overflow-hidden transition-all duration-300 ease-in-out" style="max-height: 0; opacity: 0;">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-3 gap-x-12 items-start">
        {dienstenColumns.map((col) => (
          <ul class="space-y-4">
            {col.map((d) => (
              <li>
                <a href={`/diensten/${d.slug}`} class="text-gray-300 hover:text-white transition-colors duration-200 text-lg block">
                  {d.naam}
                </a>
              </li>
            ))}
          </ul>
        ))}
      </div>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const menuToggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;
  let menuOpen = false;

  // Scroll: transparent -> solid
  function updateNavbar() {
    const dropdownIsOpen = !document.getElementById('diensten-dropdown')?.classList.contains('hidden');
    if (window.scrollY > 50 || menuOpen || dropdownIsOpen) {
      navbar.classList.add('bg-[#111]/95', 'backdrop-blur-md', 'shadow-lg');
    } else {
      navbar.classList.remove('bg-[#111]/95', 'backdrop-blur-md', 'shadow-lg');
    }
  }
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  // Mobile menu toggle
  menuToggle.addEventListener('click', () => {
    menuOpen = !menuOpen;
    mobileMenu.classList.toggle('hidden');
    menuToggle.setAttribute('aria-expanded', menuOpen.toString());

    if (menuOpen) {
      bar1.style.transform = 'rotate(45deg)';
      bar2.style.opacity = '0';
      bar3.style.transform = 'rotate(-45deg)';
    } else {
      bar1.style.transform = 'translateY(-6px)';
      bar2.style.opacity = '1';
      bar3.style.transform = 'translateY(6px)';
    }
    updateNavbar();
  });

  // Close mobile menu on link click
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false;
      mobileMenu.classList.add('hidden');
      menuToggle.setAttribute('aria-expanded', 'false');
      bar1.style.transform = 'translateY(-6px)';
      bar2.style.opacity = '1';
      bar3.style.transform = 'translateY(6px)';
      updateNavbar();
    });
  });

  // Desktop diensten dropdown
  const dienstenTrigger = document.getElementById('diensten-desktop-trigger');
  const dienstenDesktop = document.getElementById('diensten-desktop');
  const dienstenDropdown = document.getElementById('diensten-dropdown');
  const dienstenDesktopChevron = document.getElementById('diensten-desktop-chevron');
  let dropdownOpen = false;
  let closeTimeout: ReturnType<typeof setTimeout> | null = null;

  function openDropdown() {
    if (closeTimeout) { clearTimeout(closeTimeout); closeTimeout = null; }
    if (dropdownOpen) return;
    dropdownOpen = true;
    dienstenDropdown!.style.maxHeight = dienstenDropdown!.scrollHeight + 'px';
    dienstenDropdown!.style.opacity = '1';
    dienstenDesktopChevron!.style.transform = 'rotate(180deg)';
    navbar.classList.add('bg-[#111]/95', 'backdrop-blur-md', 'shadow-lg');
  }

  function closeDropdown() {
    closeTimeout = setTimeout(() => {
      dropdownOpen = false;
      dienstenDropdown!.style.maxHeight = '0';
      dienstenDropdown!.style.opacity = '0';
      dienstenDesktopChevron!.style.transform = '';
      updateNavbar();
    }, 150);
  }

  if (dienstenTrigger && dienstenDesktop && dienstenDropdown && dienstenDesktopChevron) {
    dienstenDesktop.addEventListener('mouseenter', openDropdown);
    dienstenDesktop.addEventListener('mouseleave', closeDropdown);
    dienstenDropdown.addEventListener('mouseenter', openDropdown);
    dienstenDropdown.addEventListener('mouseleave', closeDropdown);

    dienstenDropdown.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        dropdownOpen = false;
        dienstenDropdown.style.maxHeight = '0';
        dienstenDropdown.style.opacity = '0';
        dienstenDesktopChevron.style.transform = '';
        updateNavbar();
      });
    });
  }

  // Mobile diensten accordion
  const dienstenToggle = document.getElementById('diensten-mobile-toggle');
  const dienstenList = document.getElementById('diensten-mobile-list');
  const dienstenChevron = document.getElementById('diensten-chevron');

  if (dienstenToggle && dienstenList && dienstenChevron) {
    dienstenToggle.addEventListener('click', () => {
      dienstenList.classList.toggle('hidden');
      dienstenChevron.style.transform = dienstenList.classList.contains('hidden') ? '' : 'rotate(180deg)';
    });
  }
</script>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: #ffffff;
    transition: width 0.3s ease;
  }
  .nav-link:hover::after {
    width: 100%;
  }
</style>
