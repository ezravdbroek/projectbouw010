---
interface Props {
  number: number;
  title: string;
  description: string;
  icon: string;
  delay?: number;
}

const { number, title, description, icon, delay = 0 } = Astro.props;
---

<div class={`fade-in fade-in-delay-${delay} flex flex-col items-center text-center`}>
  <div class="relative mb-4">
    <div class="w-16 h-16 bg-white/5 border-2 border-white/20 rounded-full flex items-center justify-center">
      <Fragment set:html={icon} />
    </div>
    <span class="absolute -top-2 -right-2 w-7 h-7 bg-white text-primary text-sm font-bold rounded-full flex items-center justify-center">
      {number}
    </span>
  </div>
  <h3 class="text-white font-semibold text-lg mb-2">{title}</h3>
  <p class="text-gray-400 text-sm leading-relaxed max-w-xs">{description}</p>
</div>
