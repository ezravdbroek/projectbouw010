---
import { Icon } from 'astro-icon/components';

interface Props {
  quote: string;
  name: string;
  project: string;
  stars?: number;
}

const { quote, name, project, stars = 5 } = Astro.props;
const fullStars = Math.floor(stars);
const halfStar = stars % 1 >= 0.5;
---

<div class="bg-white/5 border border-white/10 rounded-lg p-5">
  <div class="flex gap-0.5 mb-3">
    {Array.from({ length: fullStars }).map(() => (
      <Icon name="lucide:star" class="w-4 h-4 fill-[#FBBC04] text-[#FBBC04]" />
    ))}
    {halfStar && (
      <Icon name="lucide:star-half" class="w-4 h-4 fill-[#FBBC04] text-[#FBBC04]" />
    )}
  </div>
  <blockquote class="text-gray-300 text-sm leading-relaxed mb-4 italic line-clamp-4">
    &ldquo;{quote}&rdquo;
  </blockquote>
  <div class="flex items-center gap-2.5">
    <div class="w-7 h-7 bg-white/10 rounded-full flex items-center justify-center text-xs font-bold text-white shrink-0">
      {name.charAt(0)}
    </div>
    <div>
      <p class="text-white font-semibold text-sm">{name}</p>
      <p class="text-gray-500 text-xs">{project}</p>
    </div>
  </div>
</div>
