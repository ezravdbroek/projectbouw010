<style>
  .floating-buttons {
    position: fixed;
    bottom: 28px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 0 24px;
    pointer-events: none;
    z-index: 9000;
  }

  /* Base floating button */
  .floating-btn {
    pointer-events: all;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    flex-shrink: 0;
  }

  .floating-btn:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.32);
  }

  .floating-icon {
    width: 26px;
    height: 26px;
  }

  /* Instagram button */
  .instagram-btn {
    background: radial-gradient(circle at 30% 110%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285AEB 90%);
    color: white;
  }

  /* WhatsApp button */
  .wa-btn {
    background-color: #25D366;
  }

  /* WhatsApp wrapper */
  .wa-wrapper {
    pointer-events: all;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }

  /* WhatsApp popup */
  .wa-popup {
    position: absolute;
    bottom: calc(100% + 14px);
    right: 0;
    width: 300px;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);
    transform: translateY(10px) scale(0.96);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease;
    transform-origin: bottom right;
  }

  .wa-popup.is-open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: all;
  }

  .wa-popup-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 18px 16px 16px;
    border-bottom: 1px solid #f0f0f0;
  }

  .wa-popup-logo {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #25D366;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .wa-popup-text {
    flex: 1;
    min-width: 0;
  }

  .wa-popup-text strong {
    display: block;
    font-size: 15px;
    font-weight: 700;
    color: #111;
    font-family: 'Source Sans 3', sans-serif;
    line-height: 1.2;
  }

  .wa-popup-text p {
    margin: 4px 0 0;
    font-size: 13.5px;
    color: #555;
    font-family: 'Source Sans 3', sans-serif;
    line-height: 1.4;
  }

  .wa-popup-close {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #f0f0f0;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #555;
    transition: background 0.15s ease;
    margin-top: -2px;
  }

  .wa-popup-close:hover {
    background: #e0e0e0;
  }

  .wa-popup-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px;
    background: #25D366;
    color: white;
    font-family: 'Source Sans 3', sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .wa-popup-cta:hover {
    background: #1eb258;
  }

  /* Mobile adjustments */
  @media (max-width: 480px) {
    .floating-buttons {
      bottom: 20px;
      padding: 0 16px;
    }

    .wa-popup {
      width: 270px;
    }
  }
</style>

<script>
  const toggle = document.getElementById('wa-toggle')!;
  const popup = document.getElementById('wa-popup')!;
  const closeBtn = document.getElementById('wa-close')!;

  // Auto-open na 10 seconden (alleen als gebruiker het nog niet zelf gesloten heeft)
  let userClosed = false;
  setTimeout(() => {
    if (!userClosed) openPopup();
  }, 10000);

  function openPopup() {
    popup.classList.add('is-open');
    toggle.setAttribute('aria-expanded', 'true');
    popup.setAttribute('aria-hidden', 'false');
  }

  function closePopup() {
    popup.classList.remove('is-open');
    toggle.setAttribute('aria-expanded', 'false');
    popup.setAttribute('aria-hidden', 'true');
  }

  toggle.addEventListener('click', () => {
    if (popup.classList.contains('is-open')) {
      closePopup();
    } else {
      openPopup();
    }
  });

  closeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    userClosed = true;
    closePopup();
  });

  // Sluit popup bij klik buiten
  document.addEventListener('click', (e) => {
    const wrapper = toggle.closest('.wa-wrapper')!;
    if (!wrapper.contains(e.target as Node)) {
      closePopup();
    }
  });
</script>
