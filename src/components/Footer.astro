---
import { Icon } from 'astro-icon/components';
import { diensten } from '../data/diensten';

const footerDiensten = diensten.slice(0, 8);
---

<footer class="bg-[#111] border-t border-white/10 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 sm:gap-10">
      <!-- Logo & beschrijving -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/logo.png" alt="Projectbouw 010" class="h-9 w-auto" />
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-6">
          Uw specialist in renovaties en verbouwingen in Rotterdam. Vakmanschap, betrouwbaarheid en persoonlijke aanpak staan bij ons centraal.
        </p>
        <div class="flex gap-3">
          <a
            href="https://wa.me/31653999433"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/5 hover:bg-white/10 rounded flex items-center justify-center transition-colors duration-200"
            aria-label="WhatsApp"
          >
            <Icon name="lucide:message-circle" class="w-5 h-5 text-white" />
          </a>
          <a
            href="https://www.instagram.com/projectbouw010"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/5 hover:bg-white/10 rounded flex items-center justify-center transition-colors duration-200"
            aria-label="Instagram"
          >
            <Icon name="lucide:instagram" class="w-5 h-5 text-white" />
          </a>
          <a
            href="https://www.facebook.com/projectbouw010"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/5 hover:bg-white/10 rounded flex items-center justify-center transition-colors duration-200"
            aria-label="Facebook"
          >
            <Icon name="lucide:facebook" class="w-5 h-5 text-white" />
          </a>
        </div>
      </div>

      <!-- Diensten -->
      <div>
        <h3 class="text-white font-semibold mb-4">Diensten</h3>
        <ul class="space-y-2">
          {footerDiensten.map((d) => (
            <li>
              <a href={`/diensten/${d.slug}`} class="text-gray-400 hover:text-white text-sm transition-colors duration-200">
                {d.naam}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Pagina's</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-gray-400 hover:text-white text-sm transition-colors duration-200">Home</a></li>
          <li><a href="/over-ons" class="text-gray-400 hover:text-white text-sm transition-colors duration-200">Over Ons</a></li>
          <li><a href="/projecten" class="text-gray-400 hover:text-white text-sm transition-colors duration-200">Projecten</a></li>
          <li><a href="/contact" class="text-gray-400 hover:text-white text-sm transition-colors duration-200">Contact</a></li>
          <li><a href="/offerte-aanvragen" class="text-gray-400 hover:text-white text-sm transition-colors duration-200">Offerte Aanvragen</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4">Contact</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <Icon name="lucide:phone" class="w-4 h-4 text-white mt-0.5 shrink-0" />
            <a href="tel:0653999433" class="text-gray-400 hover:text-white text-sm transition-colors">
              06-53999433
            </a>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="lucide:mail" class="w-4 h-4 text-white mt-0.5 shrink-0" />
            <a href="mailto:info@projectbouw010.nl" class="text-gray-400 hover:text-white text-sm transition-colors">
              info@projectbouw010.nl
            </a>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="lucide:map-pin" class="w-4 h-4 text-white mt-0.5 shrink-0" />
            <span class="text-gray-400 text-sm">Theodoor Colenbranderhof 5<br />3059 LS Rotterdam</span>
          </li>
        </ul>
        <a
          href="/offerte-aanvragen"
          class="inline-block mt-6 bg-white text-[#111] px-5 py-2.5 text-sm font-semibold rounded transition-colors duration-200 hover:bg-gray-200"
        >
          Gratis Offerte
        </a>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-sm">
        &copy; {new Date().getFullYear()} Projectbouw 010. Alle rechten voorbehouden.
      </p>
      <p class="text-gray-500 text-sm">KVK: 86943030</p>
    </div>
  </div>
</footer>
