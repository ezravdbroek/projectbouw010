---
import { Icon } from 'astro-icon/components';

const diensten = [
  'Aanbouw & Uitbouw',
  'Badkamer Renovatie',
  'Keukenrenovatie',
  'Stalen Deuren',
  'Stucwerk & Tegelwerk',
  'Traprenovatie',
];
---

<footer class="bg-primary-900 border-t border-white/10 overflow-hidden">
  <!-- Large outlined text -->
  <div class="py-8 border-b border-white/5">
    <p class="text-center text-5xl sm:text-7xl lg:text-8xl font-heading font-bold text-outline tracking-wider select-none">
      PROJECTBOUW 010
    </p>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Logo & beschrijving -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/logo.png" alt="Projectbouw 010" class="h-9 w-auto" />
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-6">
          Uw specialist in renovaties en verbouwingen in Rotterdam. Vakmanschap, betrouwbaarheid en persoonlijke aanpak staan bij ons centraal.
        </p>
        <div class="flex gap-3">
          <a
            href="https://wa.me/31653999433"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/5 hover:bg-white/10 rounded flex items-center justify-center transition-colors duration-200"
            aria-label="WhatsApp"
          >
            <Icon name="lucide:message-circle" class="w-5 h-5 text-white" />
          </a>
          <a
            href="https://www.instagram.com/projectbouw010"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/5 hover:bg-white/10 rounded flex items-center justify-center transition-colors duration-200"
            aria-label="Instagram"
          >
            <Icon name="lucide:instagram" class="w-5 h-5 text-white" />
          </a>
          <a
            href="https://www.facebook.com/projectbouw010"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/5 hover:bg-white/10 rounded flex items-center justify-center transition-colors duration-200"
            aria-label="Facebook"
          >
            <Icon name="lucide:facebook" class="w-5 h-5 text-white" />
          </a>
        </div>
      </div>

      <!-- Diensten -->
      <div>
        <h3 class="text-white font-semibold mb-4">Diensten</h3>
        <ul class="space-y-2">
          {diensten.map((dienst) => (
            <li>
              <a href="/#diensten" class="text-gray-400 hover:text-white text-sm transition-colors duration-200">
                {dienst}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4">Contact</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <Icon name="lucide:phone" class="w-4 h-4 text-gray-400 mt-0.5 shrink-0" />
            <a href="tel:0653999433" class="text-gray-400 hover:text-white text-sm transition-colors">
              06-53999433
            </a>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="lucide:mail" class="w-4 h-4 text-gray-400 mt-0.5 shrink-0" />
            <a href="mailto:info@projectbouw010.nl" class="text-gray-400 hover:text-white text-sm transition-colors">
              info@projectbouw010.nl
            </a>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="lucide:map-pin" class="w-4 h-4 text-gray-400 mt-0.5 shrink-0" />
            <span class="text-gray-400 text-sm">Rotterdam, Zuid-Holland</span>
          </li>
        </ul>
        <a
          href="/offerte"
          class="inline-block mt-6 bg-white hover:bg-gray-200 text-primary px-5 py-2.5 text-sm font-semibold rounded transition-colors duration-200"
        >
          Gratis Offerte
        </a>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-sm">
        &copy; {new Date().getFullYear()} Projectbouw 010. Alle rechten voorbehouden.
      </p>
      <p class="text-gray-500 text-sm">KVK: 78491762</p>
    </div>
  </div>
</footer>
