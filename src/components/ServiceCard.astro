---
interface Props {
  icon: string;
  title: string;
  description: string;
  delay?: number;
}

const { icon, title, description, delay = 0 } = Astro.props;
---

<div class={`fade-in fade-in-delay-${delay} group bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg p-6 transition-all duration-300 hover:-translate-y-1`}>
  <div class="w-12 h-12 bg-white/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-white/20 transition-colors duration-300">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-white font-semibold text-lg mb-2">{title}</h3>
  <p class="text-gray-400 text-sm leading-relaxed">{description}</p>
</div>
